{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "🚀 Launch ERP.Web (推薦使用)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/ERP.Web/bin/Debug/net6.0/ERP.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ERP.Web",
            "console": "internalConsole",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development",
                "ASPNETCORE_URLS": "https://localhost:44372;http://localhost:44373"
            }
        },
        {
            "name": "Launch ERP.Web (Kestrel)",
            "type": "coreclr",
            "request": "launch",
            "preLaunchTask": "build",
            "program": "${workspaceFolder}/ERP.Web/bin/Debug/net6.0/ERP.Web.dll",
            "args": [],
            "cwd": "${workspaceFolder}/ERP.Web",
            "console": "internalConsole",
            "stopAtEntry": false,
            "serverReadyAction": {
                "action": "openExternally",
                "pattern": "\\bNow listening on:\\s+(https?://\\S+)",
                "uriFormat": "%s"
            },
            "env": {
                "ASPNETCORE_ENVIRONMENT": "Development"
            }
        },
        {
            "name": "Attach to ERP.Web",
            "type": "coreclr",
            "request": "attach"
        }
    ]
}