@model ERP.Web.Utility.ViewModel.LeftSidebarViewModel
@inject Microsoft.Extensions.Options.IOptions<Dictionary<string, string>> _sharedDomain



<nav class="navbar-default navbar-static-side" role="navigation">
    <div class="sidebar-collapse">
        <ul class="nav metismenu" id="side-menu">
            @*使用者資訊*@
            <li class="nav-header">
                <div class="dropdown profile-element">
                    <img alt="image" class="rounded-circle" src="img/profile_small.jpg" />
                    <a data-toggle="dropdown" class="dropdown-toggle" href="#">
                        @*使用者名稱*@
                        <span class="block m-t-xs font-bold">王宇</span>
                        @*使用者角色權限*@
                        <span class="text-muted text-xs block">管理员 <b class="caret"></b></span>
                    </a>
                    <ul class="dropdown-menu animated fadeInRight m-t-xs">
                        <li><a class="dropdown-item" href="profile.html">个人信息</a></li>
                        <li><a class="dropdown-item" href="contacts.html">好友</a></li>
                        <li><a class="dropdown-item" href="mailbox.html">信箱</a></li>
                        <li class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="login.html">登出</a></li>
                    </ul>
                </div>
                <div class="logo-element">
                    IN+
                </div>
            </li>


            @if (Model.List != null)
            {
                @foreach (var item in Model.List
               .Where(m => m.ParentControllerMainID == Guid.Empty)
               .OrderBy(m => m.Sort))
                {
                    <li class="@(item.IsActive ? "active" : "")">
                        @if (item.Children != null && item.Children.Any())
                        {
                            <a href="#">
                                <i class="@item.IconClass"></i>
                                <span class="nav-label">@item.DisplayName</span>
                                <span class="fa arrow"></span>
                            </a>
                            <ul class="nav nav-second-level @(item.IsActive ? "in" : "collapse")">
                                @foreach (var child in item.Children.OrderBy(c => c.Sort))
                                {

                                    var childVD = new ViewDataDictionary(ViewData);
                                    childVD["Level"] = 3; // 第一次呼叫 partial 的層級（child 為第三層）

                                    @Html.Partial("_MenuItem", child, childVD)
                                }
                            </ul>
                        }
                        else
                        {
                            <a href="@item.Domain@item.Controller/@item.Action">
                                <i class="@item.IconClass"></i>
                                <span class="nav-label">@item.DisplayName</span>
                            </a>
                        }
                    </li>
                }

            }


            @*考券選單（英文／數學）— 第二層直接連結，避免選單無法展開*@
            <li>
                <a href="#"><i class="fa fa-file-text-o"></i> <span class="nav-label">考券</span> <span class="fa arrow"></span></a>
                <ul class="nav nav-second-level collapse">
                    <li class="nav-header px-3 py-1 text-muted small">英文</li>
                    <li><a href="@Url.Action("NewTest", "ExamEnglish", new { CorrectType = 0 })">英文 — 新試題</a></li>
                    <li><a href="@Url.Action("ReTest", "ExamEnglish")">英文 — 複習試題</a></li>
                    <li class="nav-header px-3 py-1 text-muted small">數學</li>
                    <li><a href="@Url.Action("NewTest", "ExamMath", new { CorrectType = 0 })">數學 — 新試題</a></li>
                    <li><a href="@Url.Action("ReTest", "ExamMath")">數學 — 複習試題</a></li>
                    <li><a href="@Url.Action("MentalTest", "ExamMath")">數學 — 心算出卷</a></li>
                    <li class="divider"></li>
                    <li><a href="@Url.Action("Index", "ExamUpload")">上傳題目</a></li>
                </ul>
            </li>

            @*後台管理Menu*@
            <li>
                <a href="index.html"><i class="fa fa-th-large"></i> <span class="nav-label">Dashboards</span> <span class="fa arrow"></span></a>
                <ul class="nav nav-second-level">
                    <li>
                        <a href="@Url.Action("Index", "Charts")">圖表</a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "SeatMap")">座位圖</a>
                    </li>
                    <li>
                        <a href="@Url.Action("Index", "AddtoCart")">加入購物車</a>
                    </li>
                </ul>
            </li>
        </ul>

    </div>
</nav>