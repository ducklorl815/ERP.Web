@model LifeTech.ERP.Utility.ViewModels.NavigationViewModel
@using LifeTech.Utility.Extension
<nav class="navbar-default navbar-static-side @(Context.Request.Query["mode"]=="modal"?"d-none":"")" role="navigation">
    <div class="sidebar-collapse">
        <ul class="nav metismenu" id="side-menu">
            <li class="nav-header">
                <div class="dropdown profile-element">
                    <img alt="image" class="rounded-circle" src="https://secure.gravatar.com/avatar/@(User.Identity.Name.ToMD5())?s=46&d=identicon" />
                    <span class="m-t-xs font-bold d-inline-block" style="color:white;"><i style="cursor:pointer;" id="sideMenuLock" title="功能列排序鎖" class="fa fa-lock"></i>@User.Identity.GetCName()</span>
                    <br />
                    <a data-toggle="dropdown" class="dropdown-toggle" href="#">
                        <span class="text-muted text-xs">@User.Identity.GetCode() <b class="caret"></b></span>
                    </a>
                    <ul class="dropdown-menu animated fadeInRight m-t-xs" style="position: absolute; top: 91px; left: 29px; will-change: top, left;">
                        <li><a class="dropdown-item" href="@(_sharedDomain.Value.ERP+"Account/PersonalInfo")">個人資訊</a></li>
                        <li><a class="dropdown-item" href="@(_sharedDomain.Value.ERP+"Account/LineNotifyInfo")">LINE通知</a></li>
                        <li><a class="dropdown-item" href="@(_sharedDomain.Value.ERP+"Attendance/PunchIn")">線上打卡</a></li>
                        @*<li><a class="dropdown-item" href="#">我的留言</a></li>
                            <li><a class="dropdown-item" href="#">郵箱</a></li>*@
                        <li class="dropdown-divider"></li>
                        <li><a class="dropdown-item" href="@(_sharedDomain.Value.ERP+"Account/Logout")">登出</a></li>
                    </ul>
                </div>
                <div class="logo-element">
                    IN+
                </div>
            </li>

            @foreach (var item in Model.List)
            {
                var controllerName = string.IsNullOrEmpty(item.ControllerName) ? string.Join(",", item.List.Select(s => s.ControllerName).Concat(item.List.SelectMany(sm => sm.List).Select(s => s.ControllerName)).GroupBy(g => g).Select(s => s.Key).Where(w => !string.IsNullOrEmpty(w))) : item.ControllerName;
                var domain = (_sharedDomain.Value)[item.ProjectName].ToString();
                var mainHref = string.IsNullOrEmpty(item.ControllerName) ? "#" : $"{domain}{item.ControllerName}/{item.ActionName}";

                <li class="@(item.IsActive?"active ":string.Empty)menu@(item.PageNumber) sortable-container menuLevel@(item.Level)" style="@(Model.CurrentPageNumber!=item.PageNumber?"display:none;":"")" data-id="@item.ID">
                    <a href="@mainHref">
                        <i class="fa @item.IconClass"></i>
                        <span class="nav-label">@item.Name</span>
                        @if (item.List.Any())
                        {
                            <span class="fa arrow"></span>
                        }
                    </a>
                    @if (item.List.Any())
                    {
                        <ul class="nav nav-second-level collapse@(item.IsActive?" in":string.Empty)">
                            @foreach (var item2 in item.List)
                            {
                                if (item2.List.Any())
                                {
                                    <li class="@(item2.IsActive?"active":string.Empty)">
                                        <a href="#">@item2.Name<span class="fa arrow"></span></a>
                                        <ul class="nav nav-third-level collapse@(item2.IsActive?" in":string.Empty)">
                                            @foreach (var item3 in item2.List)
                                            {
                                                <li class="@(item3.IsActive?"active":string.Empty)"><a href="@($"{domain}{item3.ControllerName}/{item3.ActionName}")">@item3.Name</a></li>
                                            }
                                        </ul>
                                    </li>
                                }
                                else
                                {
                                    <li class="@(item2.IsActive?"active":string.Empty)"><a href="@($"{domain}{item2.ControllerName}/{item2.ActionName}")">@item2.Name</a></li>
                                }
                            }
                        </ul>
                    }
                </li>
            }

            <li class="special_link menu1btn" style="@(Model.CurrentPageNumber==1?"display:none;":"")">
                <a onclick="$('#side-menu li.menu2,#side-menu li.menu3,.menu1btn').hide(); $('.menu1,.menu2btn,.menu3btn').show();"><i class="fa fa-indent"></i> <span class="nav-label">Menu1</span></a>
            </li>
            <li class="special_link menu2btn" style="@(Model.CurrentPageNumber==2?"display:none;":"")">
                <a onclick="$('#side-menu li.menu1,#side-menu li.menu3,.menu2btn').hide(); $('.menu2,.menu1btn,.menu3btn').show();"><i class="fa fa-indent"></i> <span class="nav-label">Menu2</span></a>
            </li>
            <li class="special_link menu3btn" style="@(Model.CurrentPageNumber==3?"display:none;":"")">
                <a onclick="$('#side-menu li.menu1,#side-menu li.menu2,.menu3btn').hide(); $('.menu3,.menu1btn,.menu2btn').show();"><i class="fa fa-indent"></i> <span class="nav-label">Menu3</span></a>
            </li>
        </ul>
    </div>
    <input id="NavERPDomainHid" type="hidden" value="@(_sharedDomain.Value.ERP)" />
</nav>