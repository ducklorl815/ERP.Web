@using Microsoft.AspNetCore.Http
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration

@{
    var slackSection = Configuration.GetSection("Slack");
    var sessionToken = Context.Session.GetString("Slack:BotToken");
    var configuredBotToken = slackSection["BotToken"];
    var hasToken = !string.IsNullOrWhiteSpace(sessionToken) || !string.IsNullOrWhiteSpace(configuredBotToken);
    var authorizeUrl = Url.Action("Authorize", "Slack");
    var messageUrl = Url.Action("SendMessage", "Slack");
    var messagesUrl = Url.Action("GetMessages", "Slack");
    var channelsUrl = Url.Action("GetChannels", "Slack");
    var defaultChannel = slackSection["DefaultChannel"] ?? string.Empty;
    var currentUserId = Context.Session.GetString("Slack:UserId") ?? string.Empty;
}

<div class="small-chat-box fadeInRight animated slack-chat-box" id="slack-small-chat" data-authorize-url="@authorizeUrl" data-message-url="@messageUrl" data-messages-url="@messagesUrl" data-channels-url="@channelsUrl" data-open-channel-url="@Url.Action("OpenChannel", "Slack")" data-default-channel="@defaultChannel" data-has-token="@hasToken.ToString().ToLower()" data-user-id="@currentUserId">
    <div class="heading" draggable="true">
        <small class="chat-date float-right">@DateTime.Now.ToString("yyyy/MM/dd")</small>
        Slack 快速訊息
    </div>
    <div class="content" id="slack-chat-content">
        <div class="text-muted small mb-2">
            此視窗僅提供快速發送訊息，歷史紀錄請至 Slack 頻道查閱。
        </div>
        <div class="alert alert-warning" role="alert" @(hasToken ? "hidden" : string.Empty) id="slack-authorize-alert">
            尚未繫結 Slack Bot，請點選
            <a href="@authorizeUrl" class="alert-link">授權 Slack</a>
            完成 OAuth 流程。
        </div>
        <div class="alert alert-info" role="alert" hidden id="slack-status-message"></div>
        <div class="slack-message-list" id="slack-message-list">
            <div class="text-center text-muted small" id="slack-message-empty">尚未載入訊息</div>
        </div>
        <button type="button" class="btn btn-link btn-sm text-primary w-100" id="slack-refresh-messages" hidden>重新整理訊息</button>
    </div>
    <div class="form-chat">
        <form id="slack-channel-form" class="mb-2" autocomplete="off">
            <div class="form-group mb-2">
                <label class="small text-muted" for="slack-channel-input">Slack Channel ID</label>
                <input type="text" class="form-control" id="slack-channel-input" placeholder="例如：C0123456789" value="@defaultChannel" @(hasToken ? string.Empty : "disabled") />
            </div>
            <div class="form-group mb-2">
                <label class="small text-muted" for="slack-channel-search">搜尋頻道</label>
                <div class="input-group input-group-sm">
                    <input type="text" class="form-control" id="slack-channel-search" placeholder="輸入頻道名稱或 ID" @(hasToken ? string.Empty : "disabled") />
                    <div class="input-group-append">
                        <button class="btn btn-outline-secondary" type="button" id="slack-load-channels" @(hasToken ? string.Empty : "disabled")>載入頻道</button>
                    </div>
                </div>
            </div>
            <div class="slack-channel-results" id="slack-channel-results">
                <div class="text-muted small">尚未載入頻道清單</div>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">可直接輸入 ID，或從清單選擇。</small>
                <button class="btn btn-secondary btn-sm" type="submit" @(hasToken ? string.Empty : "disabled")>確認頻道</button>
            </div>
        </form>
        <div class="mb-3">
            <span class="small text-muted">目前頻道：</span>
            <span id="slack-channel-display" class="font-weight-bold text-primary">@(!string.IsNullOrWhiteSpace(defaultChannel) ? defaultChannel : "尚未選擇")</span>
        </div>
        <form id="slack-chat-form" autocomplete="off">
            <div class="form-group mb-2">
                <label class="small text-muted" for="slack-message">訊息內容</label>
                <textarea class="form-control" id="slack-message" name="message" rows="3" maxlength="1000" placeholder="輸入要發送的訊息" @(hasToken ? string.Empty : "disabled")></textarea>
            </div>
            <div class="d-flex justify-content-between align-items-center">
                <small class="text-muted">先確認頻道，再輸入訊息送出。</small>
                <button class="btn btn-primary btn-sm" type="submit" @(hasToken ? string.Empty : "disabled")>發送訊息</button>
            </div>
        </form>
    </div>
</div>
<div id="small-chat" class="slack-chat-trigger">
    <span class="badge badge-primary float-right" id="slack-chat-indicator" hidden><i class="fa fa-check"></i></span>
    <a class="open-small-chat" href="javascript:void(0);">
        <i class="fa fa-slack"></i>
    </a>
</div>

<style>
    .slack-chat-box {
        bottom: 110px;
        right: 75px;
        width: 320px;
        max-height: calc(100vh - 160px);
        height: auto;
        display: flex;
        flex-direction: column;
    }

    .slack-chat-box .content {
        flex: 1 1 auto;
        overflow-y: auto;
        display: flex;
        flex-direction: column;
        gap: 10px;
    }

    .slack-chat-box .form-chat {
        flex: 0 0 auto;
        padding: 10px 15px 15px;
        overflow-y: auto;
    }

    .slack-chat-box textarea {
        min-height: 100px;
    }

    .slack-message-list {
        flex: 1 1 auto;
        overflow-y: auto;
        max-height: 260px;
        padding: 8px;
        border: 1px solid #e7eaec;
        border-radius: 4px;
        background-color: #f9f9f9;
    }

    .slack-message-list.loading {
        opacity: 0.6;
    }

    .slack-channel-results {
        max-height: 160px;
        overflow-y: auto;
        border: 1px solid #e7eaec;
        border-radius: 4px;
        padding: 6px;
        background-color: #fff;
    }

    .slack-channel-results .slack-channel-item {
        display: block;
        width: 100%;
        text-align: left;
        margin-bottom: 4px;
        font-size: 13px;
    }

    .slack-channel-results .slack-channel-item:last-child {
        margin-bottom: 0;
    }

    .slack-channel-results .slack-channel-item.active {
        background-color: #1ab394;
        border-color: #1ab394;
        color: #fff;
    }

    .slack-message-item {
        background: #fff;
        border-radius: 4px;
        padding: 6px 8px;
        margin-bottom: 6px;
        border: 1px solid transparent;
        box-shadow: 0 1px 1px rgba(0, 0, 0, 0.05);
    }

    .slack-message-item.me {
        border-color: #1ab39433;
        background-color: #e9f8f4;
    }

    .slack-message-item .slack-message-meta {
        font-size: 11px;
        color: #999;
        display: flex;
        justify-content: space-between;
        margin-bottom: 4px;
    }

    .slack-message-item .slack-message-text {
        font-size: 13px;
        word-break: break-word;
        white-space: pre-wrap;
    }

    .slack-chat-trigger {
        bottom: 110px;
        right: 20px;
    }

    @@media (max-width: 768px) {
        .slack-chat-box {
            bottom: 140px;
            right: 20px;
            width: calc(100vw - 40px);
            max-height: calc(100vh - 190px);
        }

        .slack-chat-trigger {
            bottom: 140px;
            right: 20px;
        }
    }
</style>

<script>
    (function () {
        const container = document.getElementById('slack-small-chat');
        if (!container) {
            return;
        }

        const hasToken = container.dataset.hasToken === 'true';
        const messageUrl = container.dataset.messageUrl;
        const messagesUrl = container.dataset.messagesUrl;
        const channelsUrl = container.dataset.channelsUrl;
        const openChannelUrl = container.dataset.openChannelUrl;
        const defaultChannel = container.dataset.defaultChannel || '';
        const currentUserId = container.dataset.userId || '';
        const storageKey = 'erp.slack.selectedChannel';

        const channelForm = document.getElementById('slack-channel-form');
        const channelInput = document.getElementById('slack-channel-input');
        const channelDisplay = document.getElementById('slack-channel-display');
        const channelResults = document.getElementById('slack-channel-results');
        const channelSearchInput = document.getElementById('slack-channel-search');
        const channelLoadButton = document.getElementById('slack-load-channels');
        const messageForm = document.getElementById('slack-chat-form');
        const status = document.getElementById('slack-status-message');
        const indicator = document.getElementById('slack-chat-indicator');
        const authorizeAlert = document.getElementById('slack-authorize-alert');
        const messageList = document.getElementById('slack-message-list');
        const messageEmpty = document.getElementById('slack-message-empty');
        const refreshButton = document.getElementById('slack-refresh-messages');

        if (!hasToken) {
            return;
        }

        let channelCache = [];
        let searchTimer = null;
        const showStatus = (message, type) => {
            status.textContent = message;
            status.hidden = false;
            status.classList.remove('alert-info', 'alert-success', 'alert-danger');
            status.classList.add(`alert-${type}`);
        };

        const resetStatus = () => {
            status.hidden = true;
        };

        const getStoredChannel = () => {
            try {
                return sessionStorage.getItem(storageKey) || '';
            } catch (error) {
                console.warn('無法讀取 Slack 頻道快取', error);
                return '';
            }
        };

        const setStoredChannel = (channel) => {
            try {
                sessionStorage.setItem(storageKey, channel);
            } catch (error) {
                console.warn('無法寫入 Slack 頻道快取', error);
            }
        };

        const updateChannelDisplay = (channel) => {
            if (!channelDisplay) {
                return;
            }

            channelDisplay.textContent = channel || '尚未選擇';
            channelDisplay.classList.toggle('text-primary', !!channel);
            channelDisplay.classList.toggle('text-danger', !channel);
        };

        const renderChannelResults = (channels) => {
            if (!channelResults) {
                return;
            }

            channelResults.innerHTML = '';

            if (!Array.isArray(channels) || channels.length === 0) {
                const empty = document.createElement('div');
                empty.className = 'text-muted small';
                empty.textContent = '沒有符合條件的頻道';
                channelResults.appendChild(empty);
                return;
            }

            channels.forEach((item) => {
                if (!item) {
                    return;
                }

                const channelId = item.id || '';
                const userId = item.userId || '';
                const displayName = item.displayName || item.name || channelId || userId;
                const labelSuffix = item.isIm ? '（私訊）' : (item.isPrivate ? '（私有）' : '');

                const button = document.createElement('button');
                button.type = 'button';
                button.className = 'btn btn-light btn-sm slack-channel-item';
                button.dataset.channelId = channelId;
                button.dataset.userId = userId;
                button.dataset.isNew = item.isNew ? 'true' : 'false';
                button.dataset.displayName = displayName;
                button.textContent = `${displayName} ${labelSuffix}`.trim();

                if (channelId && channelId === selectedChannel) {
                    button.classList.add('active');
                }

                button.addEventListener('click', async () => {
                    await handleChannelSelect(button);
                });

                channelResults.appendChild(button);
            });
        };

        const loadChannels = async (force = false, keyword = '') => {
            if (!channelsUrl) {
                return;
            }

            const trimmed = (keyword || '').trim();

            if (!force && !trimmed && channelCache.length > 0) {
                renderChannelResults(channelCache);
                return;
            }

            const params = new URLSearchParams();
            if (trimmed) {
                params.set('query', trimmed);
                params.set('limit', '50');
            }
            else {
                params.set('limit', '20');
            }

            showStatus(trimmed ? `搜尋 "${trimmed}" 中…` : '頻道清單載入中…', 'info');

            if (channelLoadButton) {
                channelLoadButton.disabled = true;
            }

            try {
                const response = await fetch(`${channelsUrl}?${params.toString()}`, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    const result = await response.json().catch(() => ({ message: 'Slack 頻道清單取得失敗。' }));
                    showStatus(result.message || 'Slack 頻道清單取得失敗。', 'danger');
                    return;
                }

                channelCache = await response.json();
                renderChannelResults(channelCache);
                showStatus(trimmed ? '搜尋完成。' : '頻道清單已載入。', 'success');
            } catch (error) {
                console.error('Slack load channels error', error);
                showStatus('載入頻道清單失敗，請稍後再試。', 'danger');
            } finally {
                if (channelLoadButton) {
                    channelLoadButton.disabled = false;
                }
            }
        };

        const formatTimestamp = (ts) => {
            if (!ts) {
                return '';
            }

            const unix = parseFloat(ts);
            if (Number.isNaN(unix)) {
                return ts;
            }

            const date = new Date(unix * 1000);
            return new Intl.DateTimeFormat('zh-TW', {
                month: '2-digit',
                day: '2-digit',
                hour: '2-digit',
                minute: '2-digit'
            }).format(date);
        };

        const renderMessages = (messages) => {
            if (!messageList) {
                return;
            }

            messageList.innerHTML = '';

            if (!messages || messages.length === 0) {
                const empty = document.createElement('div');
                empty.className = 'text-center text-muted small';
                empty.textContent = '目前沒有訊息';
                messageList.appendChild(empty);
                return;
            }

            const list = Array.isArray(messages) ? messages : [];

            list.forEach((item) => {
                if (!item || item.subtype === 'channel_join') {
                    return;
                }

                const wrapper = document.createElement('div');
                const isMe = currentUserId && item.user === currentUserId;
                wrapper.className = `slack-message-item${isMe ? ' me' : ''}`;

                const meta = document.createElement('div');
                meta.className = 'slack-message-meta';
                meta.innerHTML = `<span>${isMe ? '我' : (item.user || '未知使用者')}</span><span>${formatTimestamp(item.ts)}</span>`;

                const text = document.createElement('div');
                text.className = 'slack-message-text';
                text.textContent = item.text || '';

                wrapper.appendChild(meta);
                wrapper.appendChild(text);
                messageList.appendChild(wrapper);
            });

            messageList.scrollTop = messageList.scrollHeight;
        };

        const setLoadingState = (isLoading) => {
            if (!messageList) {
                return;
            }

            messageList.classList.toggle('loading', !!isLoading);
        };

        const fetchMessages = async (channel, displayStatus = true) => {
            if (!messagesUrl || !channel) {
                return;
            }

            if (displayStatus) {
                showStatus('訊息載入中…', 'info');
            }

            setLoadingState(true);

            try {
                const response = await fetch(`${messagesUrl}?channel=${encodeURIComponent(channel)}&limit=20`, {
                    method: 'GET',
                    headers: {
                        'Accept': 'application/json'
                    }
                });

                if (!response.ok) {
                    const result = await response.json().catch(() => ({ message: 'Slack 訊息讀取失敗。' }));
                    showStatus(result.message || 'Slack 訊息讀取失敗。', 'danger');
                    return;
                }

                const messages = await response.json();
                renderMessages(messages);
                if (displayStatus) {
                    showStatus('訊息已更新。', 'success');
                }
            } catch (error) {
                console.error('Fetch Slack messages error', error);
                showStatus('讀取 Slack 訊息失敗，請稍後再試。', 'danger');
            } finally {
                setLoadingState(false);
            }
        };

        const startAutoRefresh = () => {
            if (!selectedChannel) {
                return;
            }

            fetchMessages(selectedChannel, false);

            if (refreshButton) {
                refreshButton.hidden = false;
                refreshButton.disabled = false;
                if (!refreshButton.dataset.bound) {
                    refreshButton.addEventListener('click', () => {
                        fetchMessages(selectedChannel);
                    });
                    refreshButton.dataset.bound = 'true';
                }
            }

            if (messageEmpty) {
                messageEmpty.remove();
            }

            if (!container.dataset.refreshInitialized) {
                setInterval(() => {
                    if (selectedChannel) {
                        fetchMessages(selectedChannel, false);
                    }
                }, 20000);
                container.dataset.refreshInitialized = 'true';
            }
        };

        const applySelectedChannel = (channel, alias, showMessage) => {
            if (!channel) {
                return;
            }

            selectedChannel = channel;
            setStoredChannel(channel);
            updateChannelDisplay(alias || channel);

            if (channelInput) {
                channelInput.value = channel;
            }

            indicator.hidden = false;

            if (showMessage) {
                showStatus(`頻道 ${alias || channel} 已更新。`, 'success');
            }

            if (channelCache.length) {
                renderChannelResults(channelCache);
            }

            startAutoRefresh();
        };

        const ensureChannelInCache = (channelId, displayName, userId) => {
            if (!channelId) {
                return;
            }

            const existing = channelCache.find(item => item && item.id === channelId);
            if (existing) {
                existing.displayName = displayName || existing.displayName;
                existing.userId = userId || existing.userId;
                existing.isNew = false;
            }
            else {
                channelCache.unshift({
                    id: channelId,
                    name: null,
                    displayName,
                    isIm: !!userId,
                    isPrivate: !userId,
                    isMpim: false,
                    memberCount: null,
                    userId: userId || '',
                    isNew: false
                });
            }
        };

        const handleChannelSelect = async (button) => {
            if (!button) {
                return;
            }

            let channelId = button.dataset.channelId || '';
            const userId = button.dataset.userId || '';
            const displayName = button.dataset.displayName || button.textContent.trim();
            const isNew = button.dataset.isNew === 'true';

            if ((!channelId || isNew) && userId && openChannelUrl) {
                showStatus('正在建立私訊…', 'info');
                try {
                    const response = await fetch(openChannelUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ userId })
                    });

                    if (!response.ok) {
                        const result = await response.json().catch(() => ({ message: 'Slack 開啟對話失敗。' }));
                        showStatus(result.message || 'Slack 開啟對話失敗。', 'danger');
                        return;
                    }

                    const result = await response.json();
                    channelId = result.channelId;
                    ensureChannelInCache(channelId, displayName, userId);
                    button.dataset.channelId = channelId;
                    button.dataset.isNew = 'false';
                    showStatus('私訊已建立。', 'success');
                } catch (error) {
                    console.error('Slack open conversation error', error);
                    showStatus('建立私訊失敗，請稍後再試。', 'danger');
                    return;
                }
            }

            if (!channelId) {
                showStatus('無法取得頻道資訊，請稍後再試。', 'danger');
                return;
            }

            applySelectedChannel(channelId, displayName, true);
            renderChannelResults(channelCache);
        };

        let selectedChannel = getStoredChannel() || defaultChannel;
        updateChannelDisplay(selectedChannel);

        if (channelInput) {
            channelInput.value = selectedChannel;
        }

        if (messageForm) {
            messageForm.addEventListener('submit', async (event) => {
                event.preventDefault();
                resetStatus();

                const messageInput = messageForm.querySelector('#slack-message');
                const text = messageInput ? messageInput.value.trim() : '';

                if (!selectedChannel) {
                    showStatus('請先選擇頻道或私訊對象。', 'danger');
                    return;
                }

                if (!text) {
                    showStatus('請輸入訊息內容。', 'danger');
                    return;
                }

                showStatus('傳送中，請稍候…', 'info');

                try {
                    const response = await fetch(messageUrl, {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/json'
                        },
                        body: JSON.stringify({ channel: selectedChannel, text })
                    });

                    const result = await response.json();

                    if (response.ok) {
                        showStatus(result.message || '訊息已成功傳送。', 'success');
                        indicator.hidden = false;
                        if (messageInput) {
                            messageInput.value = '';
                        }
                        fetchMessages(selectedChannel, false);
                    } else {
                        showStatus(result.message || 'Slack 傳送失敗，請稍後再試。', 'danger');
                    }
                } catch (error) {
                    console.error('Slack send message error', error);
                    showStatus('無法連線到 Slack 服務，請稍後再試。', 'danger');
                }
            });
        }

        if (channelForm) {
            channelForm.addEventListener('submit', (event) => {
                event.preventDefault();
                resetStatus();

                const channel = channelInput ? channelInput.value.trim() : '';

                if (!channel) {
                    showStatus('請輸入 Slack 頻道 ID（例如 C 開頭）。', 'danger');
                    return;
                }

                applySelectedChannel(channel, channel, true);
            });
        }

        if (channelLoadButton) {
            channelLoadButton.addEventListener('click', () => {
                loadChannels(true, channelSearchInput ? channelSearchInput.value : '');
            });
        }

        if (channelSearchInput) {
            channelSearchInput.addEventListener('input', () => {
                if (searchTimer) {
                    clearTimeout(searchTimer);
                }

                const keyword = channelSearchInput.value.trim();

                searchTimer = setTimeout(() => {
                    if (keyword) {
                        loadChannels(true, keyword);
                    }
                    else {
                        loadChannels(false, '');
                    }
                }, 300);
            });
        }

        if (channelsUrl) {
            loadChannels(false, '');
        }

        if (selectedChannel) {
            startAutoRefresh();
        }
    })();
</script>