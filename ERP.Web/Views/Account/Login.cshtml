@{
    Layout = null; // 登入頁面不使用 Layout，使用獨立的完整 HTML
}

<!DOCTYPE html>
<html lang="zh-hant-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>使用者登入 - ERP.Web</title>

    <!-- Bootstrap 樣式 -->
    <link rel="stylesheet" href="~/StaticFiles/lib/bootstrap/dist/css/bootstrap.css" />
    
    <!-- Font Awesome 圖示 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    
    <!-- Animate.css 動畫特效 -->
    <link rel="stylesheet" href="~/StaticFiles/css/animate.css" />
    
    <!-- 自訂樣式 -->
    <link rel="stylesheet" href="~/StaticFiles/css/style.css" />

    <style>
        /* 登入頁面專用樣式 - 基於 #2f4050 色系設計 */
        
        /* 主色調定義 */
        :root {
            --primary-color: #2f4050;          /* 主色：深藍灰 */
            --primary-dark: #1a242f;           /* 深色變體：更深的藍灰 */
            --primary-light: #3d5266;          /* 淺色變體：較亮的藍灰 */
            --primary-lighter: #4a6380;        /* 更亮的藍灰（左側區域用） */
            --primary-lightest: #5a7a9a;       /* 最亮的藍灰（左側漸層終點） */
            --accent-color: #3498db;           /* 強調色：藍色 */
            --text-light: #ecf0f1;             /* 淺色文字 */
            --text-dark: #2c3e50;              /* 深色文字 */
        }

        body {
            /* 深藍灰漸層背景 */
            background: linear-gradient(135deg, #2f4050 0%, #1a242f 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Microsoft JhengHei', 'Segoe UI', sans-serif;
            position: relative;
        }

        /* 背景裝飾圖案 */
        body::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                radial-gradient(circle at 20% 30%, rgba(52, 152, 219, 0.1) 0%, transparent 50%),
                radial-gradient(circle at 80% 70%, rgba(61, 82, 102, 0.15) 0%, transparent 50%);
            pointer-events: none;
        }

        .loginColumns {
            width: 100%;
            max-width: 1200px;
            margin: 40px auto;
            padding: 0 20px;
            position: relative;
            z-index: 1;
        }

        .row {
            background: white;
            border-radius: 12px;
            box-shadow: 
                0 15px 50px rgba(26, 36, 47, 0.3),
                0 5px 15px rgba(26, 36, 47, 0.2);
            overflow: hidden;
        }

        .col-md-6 {
            padding: 50px;
        }

        /* 左側說明區域 - 使用較亮的色調 */
        .col-md-6:first-child {
            background: linear-gradient(135deg, var(--primary-lighter) 0%, var(--primary-lightest) 100%);
            color: var(--text-light);
            position: relative;
        }

        /* 左側裝飾圖案 */
        .col-md-6:first-child::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background-image: 
                repeating-linear-gradient(
                    45deg,
                    transparent,
                    transparent 10px,
                    rgba(255, 255, 255, 0.03) 10px,
                    rgba(255, 255, 255, 0.03) 20px
                );
            pointer-events: none;
        }

        /* 左側標題樣式 */
        .col-md-6:first-child h2 {
            font-size: 32px;
            font-weight: 700;
            color: white;
            margin-bottom: 25px;
            text-shadow: 0 2px 4px rgba(0, 0, 0, 0.15);
            position: relative;
        }

        /* 左側段落文字 */
        .col-md-6:first-child p {
            font-size: 16px;
            line-height: 1.8;
            color: rgba(255, 255, 255, 0.95);
            margin-bottom: 20px;
            position: relative;
        }

        /* 右側登入表單區域 */
        .ibox-content {
            background: #ffffff;
            border-radius: 8px;
            padding: 40px;
            box-shadow: 0 2px 8px rgba(47, 64, 80, 0.08);
            border: 1px solid rgba(47, 64, 80, 0.1);
            position: relative;
            margin-top: 10px;
        }

        /* 表單頂部裝飾條 */
        .ibox-content::before {
            content: '';
            position: absolute;
            top: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 60px;
            height: 4px;
            background: linear-gradient(90deg, var(--primary-color) 0%, var(--accent-color) 100%);
            border-radius: 0 0 4px 4px;
        }

        /* 表單群組間距 */
        .form-group {
            margin-bottom: 20px;
        }

        /* 輸入框樣式 */
        .form-control {
            height: 48px;
            padding: 12px 16px;
            font-size: 15px;
            border: 2px solid rgba(47, 64, 80, 0.2);
            border-radius: 6px;
            transition: all 0.3s ease;
            background-color: #fafbfc;
        }

        .form-control:focus {
            border-color: var(--accent-color);
            box-shadow: 0 0 0 0.2rem rgba(52, 152, 219, 0.15);
            background-color: white;
            outline: none;
        }

        .form-control::placeholder {
            color: #95a5a6;
        }

        /* 登入按鈕樣式 */
        button[type="submit"] {
            width: 100%;
            height: 48px;
            font-size: 16px;
            font-weight: 600;
            background: linear-gradient(135deg, var(--primary-color) 0%, var(--primary-light) 100%);
            border: none;
            border-radius: 6px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 12px rgba(47, 64, 80, 0.3);
            color: white;
            cursor: pointer;
            margin-bottom: 20px;
        }

        button[type="submit"]:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(47, 64, 80, 0.4);
            background: linear-gradient(135deg, var(--primary-light) 0%, var(--accent-color) 100%);
        }

        button[type="submit"]:active {
            transform: translateY(0);
            box-shadow: 0 2px 8px rgba(47, 64, 80, 0.3);
        }

        /* Checkbox 樣式 */
        input[type="checkbox"] {
            margin-right: 8px;
            cursor: pointer;
            accent-color: var(--primary-color);
        }

        label {
            cursor: pointer;
            user-select: none;
            color: var(--text-dark);
        }

        /* 錯誤訊息樣式 */
        .error-message {
            color: #e74c3c;
            font-size: 14px;
            margin-bottom: 15px;
            padding: 12px 16px;
            background-color: #fdeaea;
            border: 1px solid #f5c6cb;
            border-left: 4px solid #e74c3c;
            border-radius: 5px;
            display: none;
        }

        /* 分隔線樣式 */
        hr {
            border-top: 1px solid rgba(47, 64, 80, 0.1);
            margin: 0;
        }

        /* 淡入動畫設定 */
        .loginColumns.animated {
            animation-duration: 0.8s;
        }

        /* 響應式設計 */
        @@media (max-width: 768px) {
            .col-md-6 {
                padding: 30px;
            }

            .col-md-6:first-child h2 {
                font-size: 24px;
            }

            .ibox-content {
                padding: 30px 20px;
            }
        }
    </style>
</head>
<body>
    <div class="loginColumns animated fadeInDown">
        <div class="row">
            <!-- 左側 - 歡迎訊息與說明 -->
            <div class="col-md-6">
                <h2>Welcome to ERP System</h2>
                <p>
                    歡迎使用企業資源規劃管理系統（ERP），本系統整合了企業核心業務流程，
                    提供完整的管理解決方案，協助您提升工作效率，優化資源配置。
                </p>
                <p>
                    系統特色包括：模組化設計、直覺式操作介面、即時數據分析、完善的權限管理。<br />
                    我們致力於提供穩定可靠的系統服務，讓您專注於核心業務發展。
                </p>
            </div>

            <!-- 右側 - 登入表單 -->
            <div class="col-md-6">
                <div class="ibox-content">
                    <form asp-action="Login" method="post" role="form" autocomplete="off" id="loginForm">
                        <!-- 帳號欄位 -->
                        <div class="form-group">
                            <input type="text" name="Account" class="form-control" placeholder="請輸入帳號" required autocomplete="username" />
                        </div>
                        
                        <!-- 密碼欄位 -->
                        <div class="form-group">
                            <input type="password" name="Password" class="form-control" placeholder="請輸入密碼" required autocomplete="current-password" />
                        </div>
                        
                        <!-- 錯誤訊息顯示區域 -->
                        <div class="error-message" id="errorMessage"></div>
                        
                        <!-- 登入按鈕 -->
                        <button type="submit">登入</button>
                        
                        <!-- 自動登入選項 -->
                        <div style="display: flex; justify-content: flex-end;">
                            <label>
                                <input type="checkbox" name="AutoLogin" value="true">
                                自動登入
                            </label>
                        </div>
                    </form>
                </div>
            </div>
        </div>
        <hr />
    </div>

    <!-- jQuery -->
    <script src="~/StaticFiles/lib/jquery/dist/jquery-3.7.1.min.js"></script>
    
    <!-- Bootstrap JS -->
    <script src="~/StaticFiles/lib/bootstrap/dist/js/bootstrap.js"></script>

    <script>
        $(document).ready(function () {
            // 如果有錯誤訊息，顯示出來（使用 JSON 編碼，避免 XSS）
            var errorMsg = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(TempData["ErrorMessage"]?.ToString() ?? ""));
            if (errorMsg && errorMsg.trim() !== '') {
                $('#errorMessage').text(errorMsg).show();
            }

            // 表單驗證
            $('#loginForm').on('submit', function (e) {
                var account = $('input[name="Account"]').val().trim();
                var password = $('input[name="Password"]').val().trim();
                
                // 檢查欄位是否為空
                if (account === '' || password === '') {
                    e.preventDefault();
                    $('#errorMessage').text('請輸入帳號和密碼').show();
                    return false;
                }
                
                // 隱藏錯誤訊息
                $('#errorMessage').hide();
            });

            // 輸入時隱藏錯誤訊息
            $('input[name="Account"], input[name="Password"]').on('input', function () {
                $('#errorMessage').hide();
            });
        });
    </script>
</body>
</html>

