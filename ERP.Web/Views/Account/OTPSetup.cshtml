@model ERP.Web.Service.ViewModels.Account.OTPSetupViewModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "OTP 設定";
}

<div class="container mt-4">
    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h4><i class="fas fa-shield-alt"></i> OTP 雙因素驗證設定</h4>
                </div>
                <div class="card-body">
                    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
                    {
                        <div class="alert alert-danger">
                            <i class="fas fa-exclamation-circle"></i> @Model.ErrorMessage
                        </div>
                    }

                    @if (Model.IsOTPEnabled)
                    {
                        <!-- 已啟用 OTP -->
                        <div class="alert alert-success">
                            <i class="fas fa-check-circle"></i> OTP 雙因素驗證已啟用
                        </div>

                        <div class="text-center mt-4">
                            <button type="button" class="btn btn-danger" onclick="disableOTP()">
                                <i class="fas fa-times"></i> 停用 OTP
                            </button>
                        </div>
                    }
                    else if (!string.IsNullOrEmpty(Model.QRCodeUrl))
                    {
                        <!-- 顯示 QR Code 和設定步驟 -->
                        <div class="alert alert-info">
                            <i class="fas fa-info-circle"></i> 請按照以下步驟完成 OTP 設定
                        </div>

                        <div class="setup-steps">
                            <h5>設定步驟：</h5>
                            <ol>
                                <li>在您的手機上安裝驗證器 App（如 Google Authenticator、Microsoft Authenticator）</li>
                                <li>使用驗證器 App 掃描下方的 QR Code</li>
                                <li>或手動輸入 Secret Key：<code>@Model.SecretKey</code></li>
                                <li>在驗證器 App 中輸入顯示的 6 位數驗證碼進行驗證</li>
                            </ol>
                        </div>

                        <div class="text-center mt-4">
                            <div id="qrcode"></div>
                            <p class="mt-3">
                                <small class="text-muted">Secret Key: <code>@Model.SecretKey</code></small>
                            </p>
                        </div>

                        <div class="mt-4">
                            <h5>驗證設定：</h5>
                            <form id="verifyForm" onsubmit="verifyOTPSetup(event)">
                                <div class="form-group">
                                    <label for="verifyCode">請輸入驗證器 App 中顯示的驗證碼：</label>
                                    <input type="text" 
                                           id="verifyCode" 
                                           class="form-control" 
                                           placeholder="000000" 
                                           maxlength="6"
                                           pattern="[0-9]{6}"
                                           required />
                                </div>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-check"></i> 驗證並啟用
                                </button>
                            </form>
                        </div>
                    }
                    else
                    {
                        <!-- 尚未設定，顯示設定按鈕 -->
                        <div class="alert alert-warning">
                            <i class="fas fa-exclamation-triangle"></i> 您尚未設定 OTP 雙因素驗證
                        </div>

                        <div class="text-center mt-4">
                            <form asp-action="OTPSetup" method="post">
                                <input type="hidden" name="account" value="@Model.Account" />
                                <button type="submit" class="btn btn-primary btn-lg">
                                    <i class="fas fa-plus-circle"></i> 開始設定 OTP
                                </button>
                            </form>
                        </div>

                        <div class="mt-4">
                            <h5>什麼是 OTP 雙因素驗證？</h5>
                            <p>OTP（One-Time Password）雙因素驗證是一種安全機制，除了帳號密碼外，還需要輸入驗證器 App 產生的動態驗證碼才能登入，大幅提升帳號安全性。</p>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

<!-- QR Code 生成庫 -->
<script src="https://cdn.jsdelivr.net/npm/qrcodejs@1.0.0/qrcode.min.js"></script>

<script>
    // 生成 QR Code
    @if (!string.IsNullOrEmpty(Model.QRCodeUrl))
    {
        <text>
        document.addEventListener('DOMContentLoaded', function() {
            var qrcode = new QRCode(document.getElementById("qrcode"), {
                text: "@Model.QRCodeUrl",
                width: 256,
                height: 256,
                colorDark: "#000000",
                colorLight: "#ffffff",
                correctLevel: QRCode.CorrectLevel.H
            });
        });
        </text>
    }

    // 驗證 OTP 設定
    function verifyOTPSetup(event) {
        event.preventDefault();
        var verifyCode = document.getElementById('verifyCode').value;
        if (verifyCode.length !== 6) {
            alert('請輸入 6 位數驗證碼');
            return;
        }

        // 這裡應該呼叫後端 API 驗證
        // 暫時使用表單提交
        var form = document.createElement('form');
        form.method = 'POST';
        form.action = '@Url.Action("VerifyOTP", "Account")';
        
        var accountInput = document.createElement('input');
        accountInput.type = 'hidden';
        accountInput.name = 'Account';
        accountInput.value = '@Model.Account';
        form.appendChild(accountInput);

        var codeInput = document.createElement('input');
        codeInput.type = 'hidden';
        codeInput.name = 'OTPCode';
        codeInput.value = verifyCode;
        form.appendChild(codeInput);

        document.body.appendChild(form);
        form.submit();
    }

    // 停用 OTP
    function disableOTP() {
        if (!confirm('確定要停用 OTP 雙因素驗證嗎？這可能會降低您的帳號安全性。')) {
            return;
        }

        fetch('@Url.Action("DisableOTP", "Account")', {
            method: 'POST',
            headers: {
                'Content-Type': 'application/json',
            }
        })
        .then(response => response.json())
        .then(data => {
            if (data.success) {
                alert(data.message);
                location.reload();
            } else {
                alert(data.message || '停用失敗');
            }
        })
        .catch(error => {
            console.error('Error:', error);
            alert('系統發生錯誤');
        });
    }

    // 限制驗證碼輸入為數字
    document.addEventListener('DOMContentLoaded', function() {
        var verifyCodeInput = document.getElementById('verifyCode');
        if (verifyCodeInput) {
            verifyCodeInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });
        }
    });
</script>

