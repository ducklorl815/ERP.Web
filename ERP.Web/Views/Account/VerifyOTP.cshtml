@model ERP.Web.Service.ViewModels.Account.OTPVerifyViewModel
@{
    Layout = null;
    ViewData["Title"] = "OTP 驗證";
}

<!DOCTYPE html>
<html lang="zh-hant-TW">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>OTP 驗證 - ERP.Web</title>

    <!-- Bootstrap 樣式 -->
    <link rel="stylesheet" href="~/StaticFiles/lib/bootstrap/dist/css/bootstrap.css" />
    
    <!-- Font Awesome 圖示 -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/7.0.1/css/all.min.css" />
    
    <!-- 自訂樣式 -->
    <link rel="stylesheet" href="~/StaticFiles/css/style.css" />

    <style>
        body {
            background: linear-gradient(135deg, #2f4050 0%, #1a242f 100%);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            font-family: 'Microsoft JhengHei', 'Segoe UI', sans-serif;
        }

        .otp-container {
            background: white;
            border-radius: 12px;
            box-shadow: 0 15px 50px rgba(26, 36, 47, 0.3);
            padding: 40px;
            max-width: 450px;
            width: 100%;
            margin: 20px;
        }

        .otp-header {
            text-align: center;
            margin-bottom: 30px;
        }

        .otp-header h2 {
            color: #2f4050;
            margin-bottom: 10px;
        }

        .otp-header p {
            color: #666;
            font-size: 14px;
        }

        .otp-icon {
            font-size: 48px;
            color: #3498db;
            margin-bottom: 20px;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-control {
            height: 50px;
            border-radius: 8px;
            border: 2px solid #e0e0e0;
            padding: 12px 16px;
            font-size: 16px;
            transition: all 0.3s;
        }

        .form-control:focus {
            border-color: #3498db;
            box-shadow: 0 0 0 3px rgba(52, 152, 219, 0.1);
        }

        .btn-primary {
            width: 100%;
            height: 50px;
            border-radius: 8px;
            background: linear-gradient(135deg, #2f4050 0%, #3498db 100%);
            border: none;
            color: white;
            font-size: 16px;
            font-weight: 600;
            transition: all 0.3s;
        }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 6px 20px rgba(47, 64, 80, 0.4);
        }

        .error-message {
            color: #e74c3c;
            font-size: 14px;
            margin-bottom: 15px;
            padding: 12px 16px;
            background-color: #fdeaea;
            border: 1px solid #f5c6cb;
            border-left: 4px solid #e74c3c;
            border-radius: 5px;
            display: none;
        }

        .help-text {
            color: #666;
            font-size: 13px;
            margin-top: 10px;
            text-align: center;
        }

        .back-link {
            text-align: center;
            margin-top: 20px;
        }

        .back-link a {
            color: #3498db;
            text-decoration: none;
        }

        .back-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="otp-container">
        <div class="otp-header">
            <div class="otp-icon">
                <i class="fas fa-shield-alt"></i>
            </div>
            <h2>OTP 驗證</h2>
            <p>請輸入您的驗證碼以完成登入</p>
        </div>

        <!-- 教學提示按鈕 -->
        <div class="text-center mb-3">
            <button type="button" class="btn btn-outline-info" id="btnShowOTPSetup" data-bs-toggle="modal" data-bs-target="#otpHelpModal">
                <i class="fas fa-question-circle"></i> 還沒有安裝驗證器 App？點擊查看教學
            </button>
        </div>

        <!-- 錯誤訊息 -->
        @if (TempData["ErrorMessage"] != null)
        {
            <div class="error-message" id="errorMessage" style="display: block;">
                @TempData["ErrorMessage"]
            </div>
        }
        
        @if (TempData["InfoMessage"] != null)
        {
            <div class="alert alert-info" style="display: block; margin-bottom: 20px;">
                <i class="fas fa-info-circle"></i> @TempData["InfoMessage"]
            </div>
        }

        <form asp-action="VerifyOTP" method="post" role="form" id="otpForm">
            <input type="hidden" name="Account" value="@ViewData["Account"]" />
            <input type="hidden" name="ReturnUrl" value="@ViewData["ReturnUrl"]" />

            <div class="form-group">
                <label for="OTPCode">驗證碼</label>
                <input type="text" 
                       name="OTPCode" 
                       id="OTPCode" 
                       class="form-control" 
                       placeholder="請輸入 6 位數驗證碼" 
                       required 
                       autocomplete="off"
                       maxlength="6"
                       pattern="[0-9]{6}"
                       autofocus />
                <div class="help-text">
                    <i class="fas fa-info-circle"></i> 請開啟您的驗證器 App（如 Google Authenticator）並輸入顯示的 6 位數驗證碼
                    <br />
                    <small class="text-muted">
                        <i class="fas fa-clock"></i> 驗證碼每 30 秒會自動更新
                    </small>
                </div>
            </div>

            <button type="submit" class="btn btn-primary">
                <i class="fas fa-check"></i> 驗證
            </button>

            <div class="back-link">
                <a href="@Url.Action("Login")">
                    <i class="fas fa-arrow-left"></i> 返回登入頁面
                </a>
            </div>
        </form>
    </div>

    <!-- Bootstrap JavaScript (用於 Modal 和折疊功能) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>
    
    <!-- OTP 設定 Modal（載入 OTPSetup 內容） -->
    <div class="modal fade" id="otpHelpModal" tabindex="-1" aria-labelledby="otpHelpModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-scrollable" style="max-width: 50%; width: 50%;">
            <style>
                @@media (max-width: 992px) {
                    #otpHelpModal .modal-dialog {
                        max-width: 90% !important;
                        width: 90% !important;
                    }
                }
                @@media (max-width: 768px) {
                    #otpHelpModal .modal-dialog {
                        max-width: 95% !important;
                        width: 95% !important;
                    }
                }
            </style>
            <div class="modal-content">
                <div class="modal-header bg-primary text-white">
                    <h5 class="modal-title" id="otpHelpModalLabel">
                        <i class="fas fa-shield-alt"></i> OTP 雙因素驗證設定
                    </h5>
                    <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body" id="otpSetupContent" style="padding: 20px; min-height: 400px;">
                    <!-- 載入中提示 -->
                    <div class="text-center py-5">
                        <div class="spinner-border text-primary" role="status">
                            <span class="visually-hidden">載入中...</span>
                        </div>
                        <p class="mt-3 text-muted">正在載入 OTP 設定...</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">關閉</button>
                </div>
            </div>
        </div>
    </div>
    
    <script>
        // 自動聚焦到驗證碼輸入框
        document.addEventListener('DOMContentLoaded', function() {
            var otpInput = document.getElementById('OTPCode');
            if (otpInput) {
                otpInput.focus();
            }

            // 限制只能輸入數字
            otpInput.addEventListener('input', function(e) {
                this.value = this.value.replace(/[^0-9]/g, '');
            });

            // 自動提交（當輸入 6 位數時）
            otpInput.addEventListener('input', function(e) {
                if (this.value.length === 6) {
                    // 可以選擇自動提交或手動提交
                    // document.getElementById('otpForm').submit();
                }
            });
        });

        // Modal 開啟時載入 OTPSetup 內容
        var otpHelpModal = document.getElementById('otpHelpModal');
        if (otpHelpModal) {
            otpHelpModal.addEventListener('show.bs.modal', function (event) {
                var modalBody = document.getElementById('otpSetupContent');
                var account = '@ViewData["Account"]';
                
                // 載入 OTPSetup PartialView
                fetch('@Url.Action("OTPSetupPartial", "Account")?account=' + encodeURIComponent(account), {
                    method: 'GET',
                    headers: {
                        'X-Requested-With': 'XMLHttpRequest'
                    }
                })
                .then(response => {
                    if (!response.ok) {
                        throw new Error('載入失敗');
                    }
                    return response.text();
                })
                .then(html => {
                    modalBody.innerHTML = html;
                })
                .catch(error => {
                    console.error('Error:', error);
                    modalBody.innerHTML = '<div class="alert alert-danger"><i class="fas fa-exclamation-triangle"></i> 載入 OTP 設定失敗，請稍後再試</div>';
                });
            });
        }
    </script>
</body>
</html>

