@model ERP.Web.Service.ViewModels.ControllerSetting.AccessGroupSearchListViewModel_result

<div class="wrapper wrapper-content animated fadeIn">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox ">
                <div class="ibox-content" style="padding:0px;">
                    <div class="panel-body">
                        <div class="panel-group" id="accordion">
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    <h5 class="panel-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapseThree" class="collapsed">搜尋條件 <i class="fa fa-hand-o-left"></i></a>
                                        <a asp-action="TreeView" asp-controller="ControllerSetting"><span class="float-right" style="cursor:pointer;"><i class="fa-solid fa-plus"></i> 新增群組</span></a>
                                    </h5>
                                </div>
                                <div id="collapseThree" class="panel-collapse collapse in (@Model.List !=null && @Model.List.Any()?" ":" show")">
                                    <div class="panel-body">
                                        <form method="get">
                                            <div class="row">
                                                <div class="col-xl-4 col-lg-6 row">
                                                    <label for="Number" class="col-sm-4 col-form-label font-weight-bold text-sm-right">群組名稱</label>
                                                    <div class="col-sm-8 input-group">
                                                        <input asp-for="Keyword.GroupName" type="text" class="form-control form-control-sm Search" placeholder="群組名稱">
                                                        <span class="input-group-append" style="height:31px;">
                                                            <button type="submit" class="btn-sm btn-success">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-xl-4 col-lg-6 row">
                                                    <label for="Number" class="col-sm-4 col-form-label font-weight-bold text-sm-right">群組描述</label>
                                                    <div class="col-sm-8 input-group">
                                                        <input asp-for="Keyword.GroupDesc" type="text" class="form-control form-control-sm Search" placeholder="群組描述">
                                                        <span class="input-group-append" style="height:31px;">
                                                            <button type="submit" class="btn-sm btn-success">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>

                                                <div class="col-xl-4 col-lg-6 row">
                                                    <div class="row text-right" style="margin-top:10px;">
                                                        <div class="col">
                                                            <button class="btn btn-success btn-sm" type="submit"><i style="width:12px;" class="fa fa-search"></i> 搜尋</button>
                                                            <button class="btn btn-default btn-sm SearchClearBtn" type="button"><i style="width:12px;" class="fa fa-times"></i> 清除</button>
                                                            <button class="btn btn-default btn-sm SearchShrinkBtn" type="button"><i style="width:12px;" class="fa fa-angle-double-up"></i> 縮合</button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div id="partial" class="ibox-content ibox-list-content">
                    @await Html.PartialAsync("_AccessGroupSearchList", Model)
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    function DeleteAccessGroup(ID) {
        $.ajax({
            url: '/ControllerSetting/DeleteAccessGroup/?ID=' + ID,
            type: 'GET',
            success: function (result) {
                alert("刪除成功！");
                // 移除畫面上對應的那一行
                $('[data-id="' + ID + '"]').closest('tr').remove();
            },
            error: function (err) {
                console.error("送出失敗：", err);
                alert("送出失敗！");
            }
        });
    }

</script>