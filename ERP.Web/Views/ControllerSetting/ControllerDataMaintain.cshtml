@model ERP.Web.Service.ViewModels.ControllerSetting.ControllerSettingDataMaintainViewModel_result

<!-- Select2 CSS -->
<link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
<style>
    /* 針對你的 Modal ID 調整 */
    #IconClassPreview .modal-dialog {
        max-width: 90%; /* 最大寬度 90% */
        width: auto; /* 自動寬度 */
        height: 90vh; /* 高度 90%  */
        margin: 1.5rem auto; /* 上下間距 */
    }

    #IconClassPreview .modal-content {
        height: 100%; /* 讓內容滿高度 */
        overflow-y: auto; /* 超過內容可滾動 */
    }
</style>
<div class="wrapper wrapper-content animated fadeIn">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-content">
                    <form id="ControllerDataMaintainForm" method="post" onkeydown="return event.keyCode != 13;" action="/ControllerSetting/ControllerDataMaintain" novalidate="novalidate">
                        <div class="row">
                            <div class="col-sm-12 col-form-label font-weight-bold text-right">
                                維護人日：
                                <span>廖家毅 資訊部-系統開發課</span>
                            </div>
                        </div>
                        <div class="row">
                            <label for="StationMainID" class="col-sm-2 col-form-label font-weight-bold text-sm-right">站台<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <select asp-for="@Model.ControllerMain.StationMainID" asp-items="@Model.StationListItem" class="form-control form-control-sm" style="width:100%">
                                    <option value="">請選擇</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <label for="DisplayName" class="col-sm-2 col-form-label font-weight-bold text-sm-right">顯示名稱<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <input class="form-control form-control-sm" type="text" asp-for="@Model.ControllerMain.DisplayName" value="@Model.ControllerMain.DisplayName">
                            </div>
                        </div>
                        <div class="row">
                            <label for="Controller" class="col-sm-2 col-form-label font-weight-bold text-sm-right">控制器名稱</label>
                            <div class="col-sm-10">
                                <input class="form-control form-control-sm" type="text" asp-for="@Model.ControllerMain.Controller" value="@Model.ControllerMain.Controller">
                            </div>
                        </div>
                        <div class="row">
                            <label for="Action" class="col-sm-2 col-form-label font-weight-bold text-sm-right">活動名稱</label>
                            <div class="col-sm-10">
                                <input class="form-control form-control-sm" type="text" asp-for="@Model.ControllerMain.Action" value="@Model.ControllerMain.Action">
                            </div>
                        </div>
                        <div class="row">
                            <label for="HttpMethod" class="col-sm-2 col-form-label font-weight-bold text-sm-right">使用方法</label>
                            <div class="col-sm-10">
                                <select class="form-control form-control-sm" asp-for="@Model.ControllerMain.HttpMethod">
                                    <option value=""></option>
                                    <option value="Get">Get</option>
                                    <option value="Post">Post</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <label for="ParentControllerMainID" class="col-sm-2 col-form-label font-weight-bold text-sm-right">父層級<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <select asp-for="@Model.ControllerMain.ParentControllerMainID" asp-items="@Model.ControllerListItem" class="form-control form-control-sm" style="width:100%">
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <label for="PageNumber" class="col-sm-2 col-form-label font-weight-bold text-sm-right">選單頁<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <select class="form-control form-control-sm" asp-for="@Model.ControllerMain.PageNumber">
                                    <option value=""></option>
                                    <option value="0">0</option>
                                    <option value="1">1</option>
                                    <option value="2">2</option>
                                    <option value="3">3</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <label for="IconClass" class="col-sm-2 col-form-label font-weight-bold text-sm-right">文字前面的Icon Class</label>
                            <div class="col-sm-10">
                                <input class="form-control form-control-sm" type="text" asp-for="@Model.ControllerMain.IconClass" value="@Model.ControllerMain.IconClass">
                                <span class="form-text m-b-none"><a id="OpenIconModal" href="#" class="btn btn-link"><i class="fa fa-link"></i> 參考連結</a></span>
                            </div>
                        </div>
                        <div class="row">
                            <label for="FrontNumber" class="col-sm-2 col-form-label font-weight-bold text-sm-right">文字前面的編碼</label>
                            <div class="col-sm-10">
                                <input class="form-control form-control-sm" type="text" asp-for="@Model.ControllerMain.FrontNumber" value="@Model.ControllerMain.FrontNumber">
                            </div>
                        </div>
                        <div class="row">
                            <label for="Sort" class="col-sm-2 col-form-label font-weight-bold text-sm-right">排序<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <input type="number" min="0" class="form-control form-control-sm" asp-for="@Model.ControllerMain.Sort" value="@Model.ControllerMain.Sort">
                            </div>
                        </div>
                        <div class="row">
                            <label for="IsMenu" class="col-sm-2 col-form-label font-weight-bold text-sm-right">是否顯示在Menu<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <select class="form-control form-control-sm" asp-for="@Model.ControllerMain.IsMenu">
                                    <option value=""></option>
                                    <option value="true">是</option>
                                    <option value="false">否</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <label for="isBlank" class="col-sm-2 col-form-label font-weight-bold text-sm-right">麵包屑功能方式Menu<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <select class="form-control form-control-sm" asp-for="@Model.ControllerMain.IsBlank">
                                    <option value="1" selected="">導頁</option>
                                    <option value="2">另開</option>
                                </select>
                            </div>
                        </div>
                        <div class="row">
                            <label for="ControllerDesc" class="col-sm-2 col-form-label font-weight-bold text-sm-right">敘述<span class="text-danger">*</span></label>
                            <div class="col-sm-10">
                                <input type="text" class="form-control form-control-sm" asp-for="@Model.ControllerMain.ControllerDesc" value="@Model.ControllerMain.ControllerDesc">
                            </div>
                        </div>
                        <div class="row text-right" style="margin-top:10px;">
                            <div class="col">
                                <button id="SaveBtn" class="btn btn-success btn-sm" type="submit"><i style="width:12px;" class="fa fa-save"></i> 存檔</button>
                                <button class="btn btn-default btn-sm" type="button" onclick="window.location.href='/ControllerSetting/ControllerSettingSearchList'"><i style="width:12px;" class="fa fa-times"></i> 取消</button>
                            </div>
                        </div>

                        @* 樣式光箱 *@
                        <!-- Modal -->
                        <div class="modal fade" id="IconClassPreview" tabindex="-1" role="dialog">
                            <div class="modal-dialog modal-xxl" role="document">
                                <div class="modal-content ">
                                    <div class="modal-header" style="border: 0;">
                                        <h5 class="modal-title">選擇 Icon</h5>
                                        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                                    </div>
                                    <div class="modal-body" id="icon-list-container">
                                        @* 一開始先載入第一頁 *@
                                        @await Html.PartialAsync("_IconListPartial", Model.IconGroup)
                                    </div>
                                </div>
                            </div>
                        </div>
                        <input asp-for="@Model.ControllerMain.ID" type="hidden" />
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- jQuery + Select2 -->
<script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>

<script>
    $(function () {
        // 套用全部 select
        $('select').select2({
            placeholder: "請選擇",
            allowClear: true,
            width: '100%'
        });
    });
    

    $("#SaveBtn").click(function (e) {
        
        e.preventDefault();
        $.ajax({
            url: '/ControllerSetting/EditActDataMaintain',
            type: 'POST',
            data: $("#ControllerDataMaintainForm").serialize(),
            success: function (res) {
                if (res.isSuccess) {
                    alert("修改成功！");
                } else {
                    alert("修改失敗！");
                }
            }
        });
    });




    $("#StationMainID").change(function () {
        var stationMainID = $(this).val();

        $.ajax({
            url: '/ControllerSetting/GetControllerListItem?StationMainID=' + stationMainID,
            type: 'GET',
            success: function (res) {
                if (res && res.length > 0) {
                    var $parentSelect = $("#ParentControllerMainID");
                    $parentSelect.empty(); // 先清空
                    $parentSelect.append($('<option>', { value: '', text: '請選擇' }));

                    // 動態加入選項
                    $.each(res, function (i, item) {
                        $parentSelect.append($('<option>', {
                            value: item.value,
                            text: item.text
                        }));
                    });
                } else {
                    alert("查無資料！");
                }
            },
            error: function (xhr) {
                console.error("錯誤:", xhr.responseText);
                alert("發生錯誤，請稍後再試！");
            }
        });
    });



    // 建立 callback，告訴 PageTurning 目標容器在哪裡
    var callback = function () {
        return {
            method: "get",
            url: '@Url.Action("IconList")',
            footable: true,
            wrapperContent: "#icon-list-container", // 只更新這個容器
            data: {}
        };
    };

    // 初始化分頁控制
    PageTurning(callback);

</script>


