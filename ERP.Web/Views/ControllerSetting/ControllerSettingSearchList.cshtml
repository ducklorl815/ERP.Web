@model ERP.Web.Service.ViewModels.ControllerSetting.ControllerSettingSearchListViewModel_result

<div class="wrapper wrapper-content animated fadeIn">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox ">
                <div class="ibox-content" style="padding:0px;">
                    <div class="panel-body">
                        <div class="panel-group" id="accordion">
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    <h5 class="panel-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapseThree" class="collapsed">搜尋條件 <i class="fa fa-hand-o-left"></i></a>
                                        <a asp-action="ControllerCreate" asp-controller="ControllerSetting"><span class="float-right" style="cursor:pointer;"><i class="fa-solid fa-plus"></i> 新增Controller</span></a>
                                    </h5>
                                </div>
                                <div id="collapseThree" class="panel-collapse collapse in (@Model.ControllerList !=null && @Model.ControllerList.Any()?" ":" show")">
                                    <div class="panel-body">
                                        <form method="get">
                                            <div class="row">
                                                <div class="col-xl-4 col-lg-6 row">
                                                    <label for="Number" class="col-sm-4 col-form-label font-weight-bold text-sm-right">站台碼</label>
                                                    <div class="col-sm-8 input-group">
                                                        <input asp-for="Keyword.StationCode" type="text" class="form-control form-control-sm Search" placeholder="站台碼">
                                                        <span class="input-group-append" style="height:31px;">
                                                            <button type="submit" class="btn-sm btn-success">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-xl-4 col-lg-6 row">
                                                    <label for="Number" class="col-sm-4 col-form-label font-weight-bold text-sm-right">站台</label>
                                                    <div class="col-sm-8 input-group">
                                                        <input asp-for="Keyword.Domain" type="text" class="form-control form-control-sm Search" placeholder="站台">
                                                        <span class="input-group-append" style="height:31px;">
                                                            <button type="submit" class="btn-sm btn-success">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-xl-4 col-lg-6 row">
                                                    <label for="Number" class="col-sm-4 col-form-label font-weight-bold text-sm-right">控制器</label>
                                                    <div class="col-sm-8 input-group">
                                                        <input asp-for="Keyword.Controller" type="text" class="form-control form-control-sm Search" placeholder="控制器">
                                                        <span class="input-group-append" style="height:31px;">
                                                            <button type="submit" class="btn-sm btn-success">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-xl-4 col-lg-6 row">
                                                    <label for="Number" class="col-sm-4 col-form-label font-weight-bold text-sm-right">活動名稱</label>
                                                    <div class="col-sm-8 input-group">
                                                        <input asp-for="Keyword.Action" type="text" class="form-control form-control-sm Search" placeholder="活動名稱">
                                                        <span class="input-group-append" style="height:31px;">
                                                            <button type="submit" class="btn-sm btn-success">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
                                                <div class="col-xl-4 col-lg-6 row">
                                                    <label for="Number" class="col-sm-4 col-form-label font-weight-bold text-sm-right">顯示名稱</label>
                                                    <div class="col-sm-8 input-group">
                                                        <input asp-for="Keyword.DisplayName" type="text" class="form-control form-control-sm Search" placeholder="顯示名稱">
                                                        <span class="input-group-append" style="height:31px;">
                                                            <button type="submit" class="btn-sm btn-success">
                                                                <i class="fa fa-search"></i>
                                                            </button>
                                                        </span>
                                                    </div>
                                                </div>
                                            </div>

                                            <div class="row text-right" style="margin-top:10px;">
                                                <div class="col">
                                                    <button class="btn btn-success btn-sm" type="submit"><i style="width:12px;" class="fa fa-search"></i> 搜尋</button>
                                                    <button class="btn btn-default btn-sm SearchClearBtn" type="button"><i style="width:12px;" class="fa fa-times"></i> 清除</button>
                                                    <button class="btn btn-default btn-sm SearchShrinkBtn" type="button"><i style="width:12px;" class="fa fa-angle-double-up"></i> 縮合</button>
                                                </div>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div id="partial" class="ibox-content ibox-list-content">
                    @await Html.PartialAsync("_ControllerSettingSearchList", Model)
                </div>
            </div>
        </div>
    </div>
</div>