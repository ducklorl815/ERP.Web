@using System.Text.Json
@model ERP.Web.Utility.ViewModel.LeftSidebarViewModel

<link href="~/css/ControllerSetting/controllerSettingCommon.css" rel="stylesheet" />

<div class="container mt-4">
    <!-- 新增群組輸入區 (可收合) -->
    <div class="card-section border rounded shadow-sm compact-card">
        <div class="card-header bg-light d-flex justify-content-between align-items-center compact-header"
             style="cursor:pointer" onclick="toggleSection('createSection')">
            <h5 class="mb-0"><i class="fa-solid fa-folder-plus me-1"></i>新增群組模組設定</h5>
            <i class="fa-solid fa-chevron-down toggle-icon"></i>
        </div>

        <div id="createSection" class="card-body compact-body">
            @Html.Partial("_ModuleFormPartial", Model)
        </div>
    </div>

    <!-- Controller / Action Tree -->
    <div class="card-section">
        <h5 class="mb-3 d-flex justify-content-between align-items-center">
            <span>Controller / Action 權限樹狀圖</span>
            <div>
                <button id="toggleAllBtn" class="btn btn-outline-primary btn-sm d-flex align-items-center gap-2"
                        onclick="toggleAll()"
                        title="切換全部勾選狀態">
                    <i id="toggleIcon" class="fa-solid fa-square-check"></i>
                    <span id="toggleText">全部勾選</span>
                </button>
            </div>
        </h5>

        <div id="controllerTree">
            @Html.Partial("_TreePartial", Model.List)
        </div>
    </div>
</div>

<script src="~/js/ControllerSetting/toggleSection.js"></script>
<script src="~/js/ControllerSetting/initTreeEvents.js"></script>
<script src="~/js/ControllerSetting/controllerSettingCommon.js"></script>
<script>
    // 初始化頁面
    document.addEventListener("DOMContentLoaded", function () {
        const groupList = @Html.Raw(JsonSerializer.Serialize(Model.AccessGroupList));
        initControllerSetting(groupList, false);
    });

    // 全部勾選/取消勾選功能
    function toggleAll() {
        const checkboxes = document.querySelectorAll('#controllerTree input[type="checkbox"]');
        const toggleBtn = document.getElementById('toggleAllBtn');
        const toggleIcon = document.getElementById('toggleIcon');
        const toggleText = document.getElementById('toggleText');
        
        const currentText = toggleText.textContent;
        
        if (currentText === '全部勾選') {
            checkboxes.forEach(cb => cb.checked = true);
            toggleIcon.className = 'fa-solid fa-square-xmark';
            toggleText.textContent = '取消全部勾選';
            toggleBtn.className = 'btn btn-outline-danger btn-sm d-flex align-items-center gap-2';
            expandAllTreeNodes();
        } else {
            checkboxes.forEach(cb => cb.checked = false);
            toggleIcon.className = 'fa-solid fa-square-check';
            toggleText.textContent = '全部勾選';
            toggleBtn.className = 'btn btn-outline-primary btn-sm d-flex align-items-center gap-2';
            collapseAllTreeNodes();
        }
    }

    // 展開所有樹狀節點
    function expandAllTreeNodes() {
        const treeNodes = document.querySelectorAll('#controllerTree .tree-node');
        treeNodes.forEach(node => {
            node.classList.remove('collapsed');
            node.classList.add('expanded');
        });
    }

    // 收合所有樹狀節點
    function collapseAllTreeNodes() {
        const treeNodes = document.querySelectorAll('#controllerTree .tree-node');
        treeNodes.forEach(node => {
            node.classList.add('collapsed');
            node.classList.remove('expanded');
        });
    }
</script>