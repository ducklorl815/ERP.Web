@using System.Text.Json
@model ERP.Web.Utility.ViewModel.LeftSidebarViewModel

<link href="~/css/ControllerSetting/controllerSettingCommon.css" rel="stylesheet" />

<div class="container mt-4">
    <!-- 修改模組設定區 (可收合) -->
    <div class="card-section border rounded shadow-sm">
        <div class="card-header bg-light d-flex justify-content-between align-items-center"
             style="cursor:pointer" onclick="toggleSection('editSection')">
            <h3 class="mb-0"><i class="fa-solid fa-pen-to-square me-2"></i>修改模組設定</h3>
            <i class="fa-solid fa-chevron-down toggle-icon"></i>
        </div>

        <div id="editSection" class="card-body">
            <partial name="~/Views/ControllerSetting/_ModuleEditPartial.cshtml" model="Model" />
        </div>
    </div>

    <!-- Controller / Action Tree -->
    <div class="card-section">
        <h5 class="mb-3">Controller / Action 權限樹狀圖</h5>
        <div id="controllerTree">
            <partial name="~/Views/ControllerSetting/_TreePartial.cshtml" model="Model.List" />
        </div>
    </div>
</div>

<script src="~/js/ControllerSetting/toggleSection.js"></script>
<script src="~/js/ControllerSetting/initTreeEvents.js"></script>
<script src="~/js/ControllerSetting/controllerSettingCommon.js"></script>
<script>
    // 初始化頁面
    document.addEventListener("DOMContentLoaded", function () {
        const groupList = @Html.Raw(JsonSerializer.Serialize(Model.AccessGroupList));
        initControllerSetting(groupList, true);
    });
</script>