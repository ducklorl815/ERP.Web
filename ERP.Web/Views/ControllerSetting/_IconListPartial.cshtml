@model ERP.Web.Service.ViewModels.Tools.IconGroup

<style>
    /* 滑鼠移到整個框時，整個 div 背景變黃色 */
    .icon-item:hover {
        background-color: gold;
        border-color: gold;
        color: #000;
    }
</style>

<div class="wrapper wrapper-content animated fadeIn">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox ">
                <div class="ibox-content" style="padding:0px;">
                    <div class="panel-body">
                        <div class="panel-group" id="accordion">
                            <div class="panel panel-default">
                                <div class="panel-heading">
                                    <h5 class="panel-title">
                                        <a data-toggle="collapse" data-parent="#accordion" href="#collapseThree" class="collapsed">
                                            搜尋條件 <i class="fa fa-hand-o-left"></i>
                                        </a>
                                    </h5>
                                </div>
                                <div id="collapseThree" class="panel-collapse collapse in @(Model.IconList != null && Model.IconList.Any() ? " show" : " show")">
                                    <div class="panel-body icon-search-area">

                                        <div class="row">
                                            <div class="col-xl-4 col-lg-6 row">
                                                <label for="IconClass" class="col-sm-4 col-form-label font-weight-bold text-sm-right">Icon名稱</label>
                                                <div class="col-sm-8 input-group">
                                                    <input type="text" name="IconKeyword.IconClass" class="form-control form-control-sm search-param" placeholder="Icon名稱" />
                                                    <span class="input-group-append" style="height:31px;">
                                                        <button type="button" class="btn-sm btn-success btn-search">
                                                            <i class="fa fa-search"></i>
                                                        </button>
                                                    </span>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="row text-right" style="margin-top:10px;">
                                            <div class="col">
                                                <!-- 搜尋按鈕 -->
                                                <button type="button" class="btn-sm btn-success btn-search">
                                                    <i class="fa fa-search"></i>
                                                </button>

                                                <!-- 清除 -->
                                                <button class="btn btn-default btn-sm btn-clear" type="button">
                                                    <i style="width:12px;" class="fa fa-times"></i> 清除
                                                </button>

                                                <!-- 縮合 -->
                                                <button class="btn btn-default btn-sm btn-collapse" type="button">
                                                    <i style="width:12px;" class="fa fa-angle-double-up"></i> 縮合
                                                </button>
                                            </div>
                                        </div>
                                    </div><!-- /.panel-body -->
                                </div>
                            </div>
                        </div>
                    </div><!-- /.panel-body -->
                </div>
            </div>
        </div>
    </div><!-- /.row -->

    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div id="partial" class="ibox-content ibox-list-content">
                    @await Html.PartialAsync("_IconListPartialData", Model)
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    $(function () {
        // 開啟 Modal
        $("#OpenIconModal").on("click", function (e) {
            e.preventDefault();
            $("#IconClassPreview").modal("show");
        });

        // 選取 Icon
        $("#IconClassPreview").on("click", ".icon-item", function () {
            var selectedIcon = $(this).data("icon");
            $("#ControllerMain_IconClass").val(selectedIcon);
            $("#IconClassPreview").modal("hide");
        });

        // 🔹 擷取搜尋欄位值
        function getSearchParams(containerSelector) {
            let params = {};
            $(containerSelector).find('.search-param').each(function () {
                let name = $(this).attr('name');
                if (name) params[name] = $(this).val();
            });
            return params;
        }

        // 🔹 AJAX 搜尋
        function doSearch() {
            let container = $(this).closest('.icon-search-area');
            let data = getSearchParams(container);

            let resultContainer = $('#partial');
            resultContainer.html('<div class="text-center p-3"><i class="fa fa-spinner fa-spin"></i> 載入中...</div>');

            $.ajax({
                url: '@Url.Action("IconList")',
                data: data,
                success: function (result) {
                    resultContainer.html(result);
                },
                error: function () {
                    resultContainer.html('<div class="text-center text-danger p-3">搜尋失敗，請稍後再試</div>');
                }
            });
        }

        // 🔹 清除搜尋欄位
        function clearSearch() {
            let container = $(this).closest('.icon-search-area');
            container.find('.search-param').val('');
            container.find('.btn-search').trigger('click'); // 清空後立即搜尋
        }

        // 🔹 縮合/展開搜尋區
        function toggleCollapse() {
            const panel = $(this).closest('.panel-collapse');
            panel.collapse('toggle');
            const icon = $(this).find('i');
            icon.toggleClass('fa-angle-double-up fa-angle-double-down');
        }

        // 🔹 綁定事件（class 綁定）
        $('.btn-search').on('click', doSearch);
        $('.btn-clear').on('click', clearSearch);
        $('.btn-collapse').on('click', toggleCollapse);

        // Enter 鍵觸發搜尋
        $('.icon-search-area').on('keypress', '.search-param', function (e) {
            if (e.which === 13) {
                e.preventDefault();
                $(this).closest('.icon-search-area').find('.btn-search').trigger('click');
            }
        });

        // 🔹 分頁控制
        var callback = function () {
            return {
                method: "get",
                url: '@Url.Action("IconList")',
                footable: true,
                wrapperContent: "#partial",
                data: {}
            };
        };
        PageTurning(callback);
    });

</script>
