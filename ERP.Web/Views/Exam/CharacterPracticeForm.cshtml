@model ERP.Web.Controllers.Exam.CharacterPracticeViewModel

<link href="~/css/chkboxstyle.css" rel="stylesheet" />

<div class="container mt-4">
    <h2>📝 寫生字練習紙</h2>
    <hr />

    <div class="row">
        <div class="col-md-12">
            <form id="generatePracticeSheetForm" method="post" action="@Url.Action("GenerateCharacterPracticeSheet", "ExamChinese")" target="_blank">
                <div class="card mb-3">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0">⚙️ 練習設定</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            <!-- 生字輸入 -->
                            <div class="col-md-12 mb-3">
                                <label for="characters" class="form-label">輸入要練習的生字</label>
                                <input type="text" 
                                       class="form-control form-control-lg" 
                                       id="characters" 
                                       name="characters" 
                                       placeholder="例如：一二三四五六七八九十" 
                                       value="@Model.Characters"
                                       required 
                                       maxlength="50" />
                                <small class="form-text text-muted">
                                    💡 提示：輸入要練習的中文字，系統會自動去除重複字元。例如輸入「一二三四五六七八」會生成包含這些字的練習紙。
                                </small>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-12">
                                <button type="button" class="btn btn-success btn-lg" onclick="submitPracticeSheetForm()">
                                    🎨 產生練習紙
                                </button>
                                <button type="button" class="btn btn-secondary btn-lg ms-2" onclick="location.reload()">
                                    🔄 重新設定
                                </button>
                            </div>
                        </div>
                    </div>
                </div>
            </form>
        </div>
    </div>
</div>

<script>
    function submitPracticeSheetForm() {
        var characters = $("#characters").val();

        if (!characters || characters.trim() === "") {
            alert("請輸入要練習的生字！");
            $("#characters").focus();
            return;
        }

        // 提交表單
        $("#generatePracticeSheetForm").submit();
    }
</script>

<style>
    .card-header {
        font-weight: bold;
    }
    
    .form-label {
        font-weight: 600;
        color: #333;
    }
    
    .btn-lg {
        padding: 10px 30px;
        font-size: 1.1rem;
    }

    .form-control-lg {
        font-size: 1.2rem;
        padding: 12px 16px;
    }
</style>

