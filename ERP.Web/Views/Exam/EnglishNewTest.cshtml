@model ERP.Web.Service.ViewModels.ExamSearchListViewModel_result

<link href="~/css/chkboxstyle.css" rel="stylesheet" />
<!-- 上傳移至獨立頁面 -->
<div class="mb-2">
    <a class="btn btn-secondary btn-sm" href="@Url.Action("Index","ExamUpload")">前往上傳 Excel</a>
</div>

<!-- 取得考卷 -->
<div>
    <partial name="~/Views/Exam/_GetTest.cshtml" model="Model">
</div>


<!-- 字庫區 -->
<div class="col-4">
    <label for="SelectNewClassNameList" class="form-label">選擇考卷：</label>
    <select id="SelectNewClassNameList" name="NewClassNameList" class="form-select">
        @if (Model.ClassNameList != null)
        {
            <option value="">請選擇</option>
            @foreach (var className in Model.ClassNameList)
            {
                <option value="@className">@className</option>
            }
        }
    </select>
</div>

<div id="partialContainer" class="ibox-content ibox-list-content">
    <partial name="~/Views/Exam/_EnglishNewTest.cshtml" model="Model">
</div>

<script src="~/StaticFiles/lib/select2/dist/js/select2.min.js"></script>
<script src="~/js/exam.shared.js"></script>
<script>
    $(function () {
        var $select2ClassList = $('#Select2ClassNameList');
        if ($select2ClassList.length) {
            $select2ClassList.select2({
                placeholder: '選擇考卷',
                allowClear: true,
                closeOnSelect: false,
                width: '100%'
            });
        }

        var $selectNewClassList = $('#SelectNewClassNameList');
        if ($selectNewClassList.length) {
            $selectNewClassList.select2({
                placeholder: '選擇考卷',
                allowClear: true,
                closeOnSelect: false,
                width: '100%'
            });
        }
    });

    $(document).ready(function () {
        // 上傳改為獨立頁面，移除本頁的上傳事件處理

        var debouncedReloadNewTest = ExamShared.debounce(function () {
            var ClassNameList = $("#SelectNewClassNameList").val() || [];
            var KidID = $("#KidID").val();
            $.ajax({
                url: '@Url.Action("NewTest", ViewContext.RouteData.Values["controller"]?.ToString())',
                type: 'GET',
                traditional: true, // 讓 jQuery 正確傳遞陣列
                data: {
                    ClassNameList: ClassNameList,
                    KidID: KidID
                }
            }).done(function (result) {
                $('#partialContainer').html(result);
            });
        }, 200);

        $(document).on("change", "#SelectNewClassNameList , #KidID", debouncedReloadNewTest);



        var callback = function () {
            var ClassName = $("#Class").val();
            var CorrectType = $("#CorrectType").val();
            var KidID = $("#KidID").val();
            return {
                method: "get",
                url: '@Url.Action("NewTest", ViewContext.RouteData.Values["controller"]?.ToString())',
                footable: true,
                data: {
                    ClassName: ClassName,
                    CorrectType: CorrectType,
                    KidID: KidID
                }
            };
        };
        PageTurning(callback);

    });

    function CodeMainSave(e) {
        const $row = $(e).closest("tr");
        const wordID = $(e).data("wordid");
        const isFocus = $row.find(".focus-checkbox").prop("checked");
        const question = $row.find(".question").val();
        const answer = $row.find(".answer").val();
        const kidID = $("#KidID").val();

        if (!wordID) {
            alert("請輸入考券名稱！");
            return;
        }

        if (!kidID) {
            alert("請選擇學生！");
            return;
        }

        if (!question || !answer) {
            alert("欄位資訊不可空白！");
            return;
        }
        $.ajax({
            url: '@Url.Action("UpdateNewTestWord", "Exam")',
            type: 'POST',
            data: {
                WordID: wordID,
                KidID: kidID,
                Focus: isFocus,
                Question: question,
                Answer: answer
            },
            success: function () {
                alert("資料已成功提交！");
            },
            error: function () {
                alert("提交失敗，請再試一次！");
            }
        });
    }



    function submitGenerateForm(level) {
        var KidID = $("#KidID").val();

        if (!KidID) {
            alert("請先輸入 KidID！");
            return;
        }
        // 寫入 hidden 欄位
        $("#levelInput").val(level);
        $("#KidIDInput").val(KidID);

        $("#generateForm").submit();
    }
</script>
