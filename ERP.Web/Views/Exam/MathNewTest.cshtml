@model ERP.Web.Service.ViewModels.ExamSearchListViewModel_result

<link href="~/css/chkboxstyle.css" rel="stylesheet" />

<!-- 頁面標題 -->
<div class="mb-4">
    <h2 class="text-primary">
        <i class="fa fa-graduation-cap"></i> 測驗平台
    </h2>
    <p class="text-muted">選擇四則運算測驗或珠心算測驗開始練習</p>
</div>

<!-- 全局學生選擇 -->
<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <div class="row align-items-center">
            <div class="col-md-3">
                <label class="form-label fw-bold mb-0">
                    <i class="fa fa-user text-primary"></i> 選擇學生
                </label>
            </div>
            <div class="col-md-6">
                <select id="globalKidID" class="form-select form-select-lg">
                    <option value="">請選擇學生</option>
                    @if(Model?.KidList != null)
                    {
                        @foreach (var kid in Model.KidList)
                        {
                            <option value="@kid.Value">@kid.Text</option>
                        } 
                    }
                </select>
            </div>
            <div class="col-md-3">
                <small class="text-muted">
                    <i class="fa fa-info-circle"></i> 選擇後自動套用到下方測驗
                </small>
            </div>
        </div>
    </div>
</div>

<!-- 測驗平台選擇區 -->
<partial name="~/Views/Exam/_MathTestPlatform.cshtml" model="Model" />

<!-- 四則運算測驗表單區（動態顯示） -->
<partial name="~/Views/Exam/_ArithmeticTestForm.cshtml" model="Model" />

<!-- 珠心算測驗表單區（動態顯示） -->
<partial name="~/Views/Exam/_MentalMathTestForm.cshtml" model="Model" />

<script src="~/js/exam.shared.js"></script>
<script>
    // 全局學生選擇變更時，同步到所有表單
    $(document).ready(function() {
        $("#globalKidID").on("change", function() {
            var selectedKidID = $(this).val();
            // 同步到珠心算表單（舊版）
            $("#KidID").val(selectedKidID);
            // 同步到珠心算表單（新版）
            $("#mentalMathKidID").val(selectedKidID);
            // 同步到四則運算表單
            $(".kid-select").val(selectedKidID);
        });
    });
</script>
