@using Microsoft.AspNetCore.Mvc.Rendering
@{
    ViewData["Title"] = "心算出卷";
    var kidList = ViewBag.KidList as List<SelectListItem> ?? new List<SelectListItem>();
}

<link href="~/css/exam.css" rel="stylesheet" />

<div class="wrapper wrapper-content animated fadeIn">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>心算出卷</h5>
                </div>
                <div class="ibox-content">
                    <p class="text-muted mb-3">
                        選擇學生與心算級數，系統將自動產生 30 題心算考卷（9 級：6 個數字；10 級：4 個數字）。
                    </p>

                    <form method="post" action="@Url.Action("GenerateQuestions", "ExamMath")">
                        <div class="row g-3 align-items-end">
                            <div class="col-12 col-md-4">
                                <label for="KidID" class="form-label">選擇學生</label>
                                <select id="KidID" name="KidID" class="form-select" required>
                                    <option value="">請選擇</option>
                                    @foreach (var kid in kidList)
                                    {
                                        <option value="@kid.Value">@kid.Text</option>
                                    }
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <label for="level" class="form-label">心算級數</label>
                                <select id="level" name="level" class="form-select" required>
                                    <option value="9">9 級（6 個數字）</option>
                                    <option value="10">10 級（4 個數字）</option>
                                </select>
                            </div>
                            <div class="col-12 col-md-4">
                                <button type="submit" class="btn btn-primary">產生心算考卷</button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
