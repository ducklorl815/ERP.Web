@model ERP.Web.Service.ViewModels.ExamSearchListViewModel_result
<partial name="~/Views/Exam/_ExamContext.cshtml" />
@{
    var examSubjectLabel = ViewData["ExamSubjectLabel"]?.ToString() ?? "英文";
    var isMathExam = ViewData["ExamIsMath"] as bool? == true;
}

<link href="~/css/exam.css" rel="stylesheet" />
<link href="~/StaticFiles/lib/select2/dist/css/select2.css" rel="stylesheet" />
<link href="~/StaticFiles/lib/select2/dist/css/select2-bootstrap.css" rel="stylesheet" />

<!-- 單純出考卷：選考卷 / 題數 / 學生，送出即產生考卷 -->
<div class="wrapper wrapper-content animated fadeIn">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>出考卷 — @examSubjectLabel</h5>
                    @if (isMathExam)
                    {
                        <span class="badge bg-info ms-2">數學</span>
                    }
                    else
                    {
                        <span class="badge bg-primary ms-2">英文</span>
                    }
                </div>
                <div class="ibox-content">
                    <div class="mb-3">
                        <a class="btn btn-secondary btn-sm" href="@Url.Action("Index","ExamUpload")">上傳題目</a>
                    </div>

                    <div class="card mb-3">
                        <div class="card-body">
                            <div class="d-flex flex-wrap align-items-end gap-3">
                                <div>
                                    <span class="badge bg-warning text-dark">複習考</span>
                                </div>
                                <div>
                                    <label class="form-label mb-1" for="WrongTestNumber">題數</label>
                                    <input id="WrongTestNumber" type="number" class="form-control" value="18" min="1" style="width:120px;" />
                                </div>
                                <div>
                                    <button id="btnWrongTest" type="button" class="btn btn-warning">
                                        複習考（答錯題）
                                    </button>
                                </div>
                                <div class="text-muted small">
                                    依「學生」自動抓歷史@examSubjectLabel答錯（Correct=0）的題目組卷（不限定日期）。
                                </div>
                            </div>
                        </div>
                    </div>

                    <partial name="~/Views/Exam/_GetTest.cshtml" model="Model" />
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/StaticFiles/lib/select2/dist/js/select2.min.js"></script>
<script>
    // 套用 Select2 到「選擇考卷」下拉，避免原生 multiple 撐版
    $(function () {
        var $select2ClassList = $('#Select2ClassNameList');
        if ($select2ClassList.length) {
            $select2ClassList.select2({
                placeholder: '選擇考卷',
                allowClear: true,
                closeOnSelect: false,
                width: '100%'
            });
        }

        // 複習考：按鈕跳轉到 WrongTest
        $('#btnWrongTest').on('click', function () {
            var kidId = $('#KidID').val();
            var testNumber = $('#WrongTestNumber').val() || 18;

            if (!kidId) {
                alert('請先選擇學生');
                return;
            }

            var url = '@Url.Action("WrongTest", ViewContext.RouteData.Values["controller"]?.ToString())'
                + '?KidID=' + encodeURIComponent(kidId)
                + '&TestNumber=' + encodeURIComponent(testNumber);

            window.location.href = url;
        });
    });
</script>
