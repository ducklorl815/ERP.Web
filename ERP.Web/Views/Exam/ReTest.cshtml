@using Microsoft.AspNetCore.Mvc.Rendering
@model ERP.Web.Service.ViewModels.ExamSearchListViewModel_result

<link href="~/css/chkboxstyle.css" rel="stylesheet" />
<link href="~/css/exam.css" rel="stylesheet" />
<link href="~/StaticFiles/lib/select2/dist/css/select2.css" rel="stylesheet" />
<link href="~/StaticFiles/lib/select2/dist/css/select2-bootstrap.css" rel="stylesheet" />
<style>
    .select2-container { width: 100% !important; }
    .select2-container--default .select2-selection--single {
        min-height: calc(2.25rem + 2px);
        border: 1px solid #ced4da;
        border-radius: .375rem;
    }
    .retake-filter-card {
        border: 1px solid rgba(0,0,0,.08);
        border-radius: .5rem;
        background: #fff;
        padding: 1rem;
        margin-bottom: 1rem;
    }
    .retake-filter-card .form-label { font-weight: 600; }
</style>
<div class="wrapper wrapper-content animated fadeIn">
    <div class="row">
        <div class="col-lg-12">
            <div class="ibox">
                <div class="ibox-title">
                    <h5>複習測驗（ReTest）— 依課程辭庫</h5>
                </div>
                <div class="ibox-content">
                    <div class="retake-filter-card">
                        <div class="row g-3 align-items-end">
                            <div class="col-12 col-md-4 col-lg-3">
                                <label for="KidID" class="form-label mb-1">選擇學生</label>
                                <select id="KidID" name="KidID" class="form-select">
                                    <option value="">請選擇</option>
                                    @foreach (var kid in Model.KidList ?? Enumerable.Empty<SelectListItem>())
                                    {
                                        <option value="@kid.Value" selected="@(Model.KidID == kid.Value)">@kid.Text</option>
                                    }
                                </select>
                            </div>

                            <div class="col-12 col-md-4 col-lg-3">
                                <label for="SearchText" class="form-label mb-1">搜尋（課程／問題／答案）</label>
                                <input type="text" id="SearchText" name="SearchText" class="form-control" value="@Model.SearchText" placeholder="輸入關鍵字" />
                            </div>

                            <div class="col-12 col-md-4 col-lg-2">
                                <label for="CorrectType" class="form-label mb-1">最終答題</label>
                                <select id="CorrectType" name="CorrectType" class="form-select">
                                    <option value="">全部</option>
                                    <option value="1" selected="@(Model.CorrectType == "1")">最終答對</option>
                                    <option value="0" selected="@(Model.CorrectType == "0")">最終答錯</option>
                                </select>
                            </div>

                            <div class="col-12 col-lg-4">
                                <label for="Select2ClassNameList" class="form-label mb-1">課程辭庫</label>
                                <select id="Select2ClassNameList" name="ClassNameList" class="form-select">
                                    <option value="">全部課程</option>
                                    @if (Model.ClassNameSelectList != null)
                                    {
                                        @foreach (var item in Model.ClassNameSelectList)
                                        {
                                            var selected = Model.ClassNameList?.Count == 1 && Model.ClassNameList[0] == item.Value;
                                            <option value="@item.Value" selected="@selected">@item.Text</option>
                                        }
                                    }
                                </select>
                                <div class="form-text">預設不篩課程；括號為已考題數、答對、答錯統計。</div>
                            </div>
                        </div>
                    </div>

                    <div class="mb-3">
                        <partial name="~/Views/Exam/_Customize.cshtml" model="Model" />
                    </div>

                    <div id="partial" class="ibox-content ibox-list-content p-0">
                        <partial name="~/Views/Exam/_ReTest.cshtml" model="Model" />
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<script src="~/StaticFiles/lib/select2/dist/js/select2.min.js"></script>
<script src="~/js/exam.shared.js"></script>
<script>
    var selectedWordIDs = window.selectedWordIDs || [];

    function getSelectedClassNames() {
        var v = $('#Select2ClassNameList').val();
        if (!v) return [];
        return Array.isArray(v) ? v : [v];
    }

    function initReTestSelect2() {
        var $class = $('#Select2ClassNameList');
        if (!$class.length) return;
        if ($class.data('select2')) {
            $class.select2('destroy');
        }
        $class.select2({
            placeholder: '選擇課程（可不選）',
            allowClear: true,
            width: '100%'
        });
    }

    $(function () {
        initReTestSelect2();
    });

    document.addEventListener('DOMContentLoaded', function () {
        document.body.addEventListener('change', function (event) {
            const el = event.target;
            if (el.matches && el.matches("input[type='checkbox'][name^='selectedQuestions']")) {
                const wordID = el.value;
                const kidID = document.getElementById('KidID')?.value;
                if (!kidID) return;
                if (el.checked) {
                    if (!selectedWordIDs.includes(wordID)) selectedWordIDs.push(wordID);
                } else {
                    selectedWordIDs = selectedWordIDs.filter(id => id !== wordID);
                }
                ExamShared.setCookie(`SelectedWordIDs_${kidID}`, JSON.stringify(selectedWordIDs));
            }
        });
        ExamShared.loadSelectedIdsFromCookie(document.getElementById('KidID')?.value);
    });

    $('#KidID').on('change', function () {
        var kidId = $(this).val();
        ExamShared.loadSelectedIdsFromCookie(kidId || null);
        var baseUrl = '@Url.Action("ReTest", ViewContext.RouteData.Values["controller"]?.ToString())';
        if (!kidId) {
            window.location.href = baseUrl;
            return;
        }
        window.location.href = baseUrl + '?KidID=' + encodeURIComponent(kidId);
    });

    function reloadReTestPartial() {
        var ClassNameList = getSelectedClassNames();
        var CorrectType = $("#CorrectType").val();
        var KidID = $("#KidID").val();
        var SearchText = $("#SearchText").val();
        $.ajax({
            url: '@Url.Action("ReTest", ViewContext.RouteData.Values["controller"]?.ToString())',
            type: 'GET',
            traditional: true,
            data: {
                ClassNameList: ClassNameList,
                CorrectType: CorrectType,
                KidID: KidID,
                SearchText: SearchText
            }
        }).done(function (html) {
            $('#partial').html(html);
            initReTestSelect2();
        });
    }

    $(document).ready(function () {
        $(document).on("change", "#Select2ClassNameList, #CorrectType", reloadReTestPartial);

        var searchTimer;
        $(document).on("input", "#SearchText", function () {
            clearTimeout(searchTimer);
            searchTimer = setTimeout(reloadReTestPartial, 400);
        });

        var callback = function () {
            return {
                method: "get",
                url: '@Url.Action("ReTest", ViewContext.RouteData.Values["controller"]?.ToString())',
                footable: true,
                data: {
                    ClassNameList: getSelectedClassNames(),
                    CorrectType: $("#CorrectType").val(),
                    KidID: $("#KidID").val(),
                    SearchText: $("#SearchText").val()
                }
            };
        };
        PageTurning(callback);
    });

    function CodeMainSave(e) {
        var $row = $(e).closest("tr");
        var WordID = $(e).data("wordid");
        var Question = $row.find(".question-input").val();
        var Answer = $row.find(".answer-input").val();
        var Correct = $row.find(".correct-checkbox").prop("checked");
        var KidID = $("#KidID").val();
        if (!WordID || !KidID) {
            alert("請選擇學生與題目！");
            return;
        }
        if (!Question || !Answer) {
            alert("問題與答案不可為空！");
            return;
        }
        $.ajax({
            url: '@Url.Action("UpdateExamWord", ViewContext.RouteData.Values["controller"]?.ToString())',
            type: 'POST',
            data: {
                WordID: WordID,
                KidID: KidID,
                Question: Question,
                Answer: Answer,
                Correct: Correct
            },
            success: function () { alert("已更新題目、答案與 Correct！"); reloadReTestPartial(); },
            error: function () { alert("提交失敗，請再試一次！"); }
        });
    }

    function openModal() {
        var KidID = $("#KidID").val();
        var cookieName = `SelectedWordIDs_${KidID}`;
        const selectedIdsFromCookie = JSON.parse(ExamShared.getCookieValue(cookieName) || "[]");
        selectedWordIDs = Array.isArray(selectedIdsFromCookie) ? selectedIdsFromCookie : [];
        $("#selectedWordCountValue").text(selectedWordIDs.length);
        const $examForm = $("#examForm");
        $examForm.find('input[name="selectedWordIDs"]').remove();
        selectedWordIDs.forEach(function (id) {
            $examForm.append(`<input type="hidden" name="selectedWordIDs" value="${id}" />`);
        });
        $("#modalKidID").val(KidID).change();
        var modal = new bootstrap.Modal(document.getElementById('examModal'));
        modal.show();
    }

    function closeModal() {
        var modal = bootstrap.Modal.getInstance(document.getElementById('examModal'));
        if (modal) modal.hide();
    }

    function submitExamData() {
        var KidID = $("#modalKidID").val();
        var TestType = $("#modalTestType").val();
        var ClassName = $("#modalClass").val();
        if (!KidID || !TestType || !ClassName) {
            alert("請確保所有欄位均已填寫！");
            return;
        }
        $("#examForm").submit();
    }
</script>
