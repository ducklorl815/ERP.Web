@model ERP.Web.Service.ViewModels.ExamDataViewModel_result
@using System.Text.RegularExpressions

@{
    Layout = null;  // 禁用布局
}
<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<style>
    /* 考卷格式 */
    .exam-container {
        width: 100%;
        max-width: 100%;
        margin: 0 auto;
        font-size: 20px;
        line-height: 1.5;
    }

    .question-number {
        font-weight: bold;
    }

    /* 強制換頁 */
    .page-break {
        page-break-before: always;
    }

    .exam-title {
        font-size: 14px;
        margin-top: 8px;
        margin-bottom: 8px;
        font-weight: bold;
    }

    .exam-section {
        font-size: 14px;
        margin-top: 8px;
        margin-bottom: 8px;
        font-weight: bold;
    }

    .arithmetic-table {
        width: 100%;
        border-collapse: collapse;
    }

    .arithmetic-table td {
        text-align: right;
        padding: 2px 10px;
        font-size: 24px;
        font-family: 'Courier New', Courier, monospace;
    }

    .divider {
        height: 2px;
        background-color: #000;
        margin-top: 5px;
        margin-bottom: 5px;
    }

    /* 5題一行（20% 寬度） - 螢幕和列印都適用 */
    .col-2-4 {
        flex: 0 0 auto !important;
        width: 20% !important;
        max-width: 20% !important;
        padding-left: 8px;
        padding-right: 8px;
    }

    .container {
        width: 100%;
        max-width: 100%;
        padding-left: 15px;
        padding-right: 15px;
        margin-left: auto;
        margin-right: auto;
    }

    .row {
        display: flex;
        flex-wrap: wrap;
        margin-left: -8px;
        margin-right: -8px;
    }

    /* 題目框樣式 - 增加高度讓15題撐滿頁面 */
    .question-box {
        min-height: 180px;
        display: flex;
        flex-direction: column;
        justify-content: space-between;
    }

    .mb-4 {
        margin-bottom: 2.5rem !important;
    }
</style>
@Html.Raw(@"
    <style>
        @media print {
            .page-break {
                display: block !important;
                page-break-after: always;
                break-after: page;
            }
            .container {
                width: 100% !important;
                max-width: 100% !important;
                padding-left: 10px !important;
                padding-right: 10px !important;
            }
            .row {
                display: flex !important;
                flex-wrap: wrap !important;
                margin-left: -5px !important;
                margin-right: -5px !important;
            }
            .col-2-4 {
                flex: 0 0 auto !important;
                width: 20% !important;
                max-width: 20% !important;
                padding-left: 5px !important;
                padding-right: 5px !important;
                margin-bottom: 1.8rem !important;  /* 行間距 */
            }
            /* 列印時題目框 */
            .question-box {
                min-height: 160px !important;
                padding: 10px !important;
            }
            /* 列印時表格字體和間距 */
            .arithmetic-table td {
                padding: 2px 10px !important;
                font-size: 24px !important;
                line-height: 1.4 !important;
            }
            /* 列印時輸入框 */
            .border-0 {
                padding: 12px !important;
                margin-top: 8px !important;
            }
            /* 列印時除法題目樣式 */
            .division-question {
                font-size: 22px !important;
                margin-bottom: 5px !important;
                padding: 5px !important;
                text-align: left !important;
            }
            .division-answer-area {
                min-height: 145px !important;
                height: auto !important;
                border: 2px dashed #666 !important;
                background: #f5f5f5 !important;
            }
            .division-answer-display {
                min-height: 145px !important;
                font-size: 16px !important;
                padding: 50px 10px !important;
            }
            @page {
                margin: 1cm;
                size: A4 portrait;
            }
        }
    </style>
")
</head>
<body>
<form>
    @{
        int itemsPerPage = 15; // 3行 × 5題 = 15題一頁（剛好撐滿）
        int totalQuestions = Model.VocabularyList?.Count ?? 0;
        int totalPages = (int)Math.Ceiling((double)totalQuestions / itemsPerPage);
    }

    @if (totalQuestions > 0)
    {
        <!-- 題目卷 -->
        @for (int page = 0; page < totalPages; page++)
        {
            <div class="@(page > 0 ? "page-break" : "")">
                @if (page == 0)
                {
                    // 將標題格式化為：運算類型_數學試卷_日期
                    var today = DateTime.Now.ToString("yyyyMMdd");
                    var titleParts = Model.Title?.Split('-') ?? new string[] { "" };
                    var operationType = titleParts[0]?.Trim() ?? "測驗";
                    var formattedTitle = $"{operationType}_數學試卷_{today}";
                    
                    <div style="display: flex; justify-content: space-between;">
                        <label class="exam-title">
                            @formattedTitle
                        </label>
                        <label class="exam-section mt-4">
                            姓名:______________________________
                        </label>
                    </div>
                }
                <div class="container">
                    <div class="row">
                        @for (int i = page * itemsPerPage; i < Math.Min((page + 1) * itemsPerPage, totalQuestions); i++)
                        {
                            var question = Model.VocabularyList?[i];
                            if (question == null) continue;
                            bool isDivision = question.CategoryType == "Division";
                            var lines = question.Question?.Split('\n') ?? new string[] { "" };

                            <div class="col-2-4 mb-4 text-center">
                                <div class="question-number mb-1 text-start fw-bold" style="font-size:20px">
                                    @(i + 1).
                                </div>
                                <div class="question-box border rounded p-2">
                                    @if (isDivision)
                                    {
                                        <!-- 除法：題目在同一行，大面積答題區 -->
                                        <div class="division-question" style="font-size:20px; font-family: 'Courier New', monospace; margin-bottom: 8px; text-align: center; font-weight: bold;">
                                            @question.Question
                                        </div>
                                        <div class="division-answer-area" style="min-height: 135px; border: 2px dashed #ccc; border-radius: 5px; background: #f9f9f9;">
                                            <!-- 空白區域讓學生運算 -->
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- 加減乘：垂直排列 -->
                                        <table class="arithmetic-table mx-auto">
                                            <tbody>
                                                @foreach (var line in lines)
                                                {
                                                    <tr><td>@line</td></tr>
                                                }
                                            </tbody>
                                        </table>
                                        <div class="divider"></div>
                                        <input type="text" class="border-0 text-center w-100 p-3" style="font-size:24px" />
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }

        <!-- 答案卷 -->
        @for (int page = 0; page < totalPages; page++)
        {
            <div class="page-break">
                @if (page == 0)
                {
                    <div class="exam-section">數學試卷答案</div>
                }
                <div class="container">
                    <div class="row">
                        @for (int i = page * itemsPerPage; i < Math.Min((page + 1) * itemsPerPage, totalQuestions); i++)
                        {
                            var question = Model.VocabularyList?[i];
                            if (question == null) continue;
                            bool isDivision = question.CategoryType == "Division";
                            var lines = question.Question?.Split('\n') ?? new string[] { "" };

                            <div class="col-2-4 mb-4 text-center">
                                <div class="question-number mb-1 text-start fw-bold" style="font-size:24px">
                                    @(i + 1).
                                </div>
                                <div class="question-box border rounded p-2">
                                    @if (isDivision)
                                    {
                                        <!-- 除法答案卷：題目在同一行，答案大字顯示 -->
                                        <div class="division-question" style="font-size:20px; font-family: 'Courier New', monospace; margin-bottom: 8px; text-align: center; font-weight: bold;">
                                            @question.Question
                                        </div>
                                        <div class="division-answer-display" style="min-height: 135px; font-size:28px; font-weight: bold; color: #2e7d32; text-align: center; padding: 40px 10px; background: #e8f5e9; border: 2px solid #4caf50; border-radius: 5px; display: flex; align-items: center; justify-content: center;">
                                            @question.Answer
                                        </div>
                                    }
                                    else
                                    {
                                        <!-- 加減乘答案卷：垂直排列 -->
                                        <table class="arithmetic-table mx-auto">
                                            <tbody>
                                                @foreach (var line in lines)
                                                {
                                                    <tr><td>@line</td></tr>
                                                }
                                            </tbody>
                                        </table>
                                        <div class="divider"></div>
                                        <input type="text" class="border-0 text-center w-100 p-3" style="font-size:24px" value="@question.Answer" readonly />
                                    }
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        }
    }
</form>
</body>
</html>
