@model ERP.Web.Controllers.Lession.LessionCreateViewModel
@{
    ViewData["Title"] = "新增課程片段";
}

<div class="container-fluid">
    <div class="row">
        <div class="col-12">
            <h2>新增課程片段</h2>
            <hr />
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8 col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-plus-circle"></i> 課程片段資訊</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Create" method="post" id="createForm">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- 課程選擇 -->
                        <div class="card mb-3">
                            <div class="card-header bg-info text-white">
                                <h6 class="mb-0"><i class="fas fa-book"></i> 選擇或建立課程</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="radio" name="IsNewLessionMain" id="radioExisting" value="false" checked onchange="toggleLessionMainSelection()">
                                        <label class="form-check-label" for="radioExisting">
                                            選擇現有課程
                                        </label>
                                    </div>
                                    <div id="existingLessionMainDiv">
                                        <label asp-for="LessionMainID" class="form-label"></label>
                                        <select asp-for="LessionMainID" asp-items="Model.LessionMainList" class="form-select">
                                            <option value="">-- 請選擇課程 --</option>
                                        </select>
                                        <span asp-validation-for="LessionMainID" class="text-danger"></span>
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <div class="form-check mb-3">
                                        <input class="form-check-input" type="radio" name="IsNewLessionMain" id="radioNew" value="true" onchange="toggleLessionMainSelection()">
                                        <label class="form-check-label" for="radioNew">
                                            建立新課程
                                        </label>
                                    </div>
                                    <div id="newLessionMainDiv" style="display: none;">
                                        <label asp-for="NewLessionMainName" class="form-label"></label>
                                        <input asp-for="NewLessionMainName" class="form-control" placeholder="例如: Python 基礎課程" />
                                        <span asp-validation-for="NewLessionMainName" class="text-danger"></span>
                                        <small class="form-text text-muted">建立新課程後，此片段將成為該課程的第一個片段</small>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 片段基本資訊 -->
                        <div class="card mb-3">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="fas fa-video"></i> 片段基本資訊</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label"></label>
                                    <input asp-for="Title" class="form-control" placeholder="例如: 第一章 - 基礎介紹" />
                                    <span asp-validation-for="Title" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Content" class="form-label"></label>
                                    <textarea asp-for="Content" class="form-control" rows="3" placeholder="片段內容描述..."></textarea>
                                    <span asp-validation-for="Content" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- YouTube 影片資訊 -->
                        <div class="card mb-3">
                            <div class="card-header bg-primary text-white">
                                <h6 class="mb-0"><i class="fab fa-youtube"></i> YouTube 影片資訊</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="URL" class="form-label"></label>
                                    <input asp-for="URL" class="form-control" 
                                           placeholder="https://www.youtube.com/watch?v=VIDEO_ID 或 https://youtu.be/VIDEO_ID" 
                                           id="youtubeUrl" />
                                    <span asp-validation-for="URL" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        支援格式：youtube.com/watch?v=, youtu.be/, youtube.com/embed/
                                    </small>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="URLTimeString" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="URLTimeString" class="form-control" 
                                               placeholder="例如: 10:30 或 00:10:30" 
                                               id="urlTimeString" />
                                        <button type="button" class="btn btn-outline-secondary" id="btnFetchDuration" onclick="fetchVideoDuration()">
                                            <i class="fas fa-sync-alt"></i> 自動取得
                                        </button>
                                    </div>
                                    <span asp-validation-for="URLTimeString" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        格式：HH:MM:SS（如 01:30:45）或 MM:SS（如 90:45）
                                        <span id="durationStatus" class="ms-2"></span>
                                    </small>
                                </div>

                                <!-- 預覽區域 -->
                                <div id="videoPreview" class="mb-3" style="display: none;">
                                    <div class="card">
                                        <div class="card-body">
                                            <h6 class="card-title">影片預覽</h6>
                                            <div class="embed-responsive embed-responsive-16by9" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
                                                <iframe id="previewIframe" 
                                                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                                                        frameborder="0" 
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                                        allowfullscreen>
                                                </iframe>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 圖片設定 -->
                        <div class="card mb-3">
                            <div class="card-header">
                                <h6 class="mb-0"><i class="fas fa-image"></i> 圖片設定（選填）</h6>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="Img" class="form-label"></label>
                                    <input asp-for="Img" class="form-control" placeholder="https://example.com/image.jpg" />
                                    <span asp-validation-for="Img" class="text-danger"></span>
                                    <small class="form-text text-muted">課程列表顯示的封面圖片</small>
                                </div>
                            </div>
                        </div>

                        <!-- 操作按鈕 -->
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index", "Lession")" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> 返回列表
                            </a>
                            <div>
                                <button type="button" class="btn btn-info" onclick="previewVideo()">
                                    <i class="fas fa-eye"></i> 預覽影片
                                </button>
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> 儲存
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- 右側：說明 -->
        <div class="col-lg-4 col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> 使用說明</h5>
                </div>
                <div class="card-body">
                    <h6>填寫說明：</h6>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <strong>選擇或建立課程：</strong><br>
                            <small>可以選擇現有課程新增片段，或建立新課程（此片段將成為第一個片段）</small>
                        </li>
                        <li class="mb-2">
                            <strong>片段標題：</strong><br>
                            <small>此片段的標題，會顯示在播放清單中</small>
                        </li>
                        <li class="mb-2">
                            <strong>YouTube URL：</strong><br>
                            <small>支援多種格式：<br>
                            • https://www.youtube.com/watch?v=VIDEO_ID<br>
                            • https://youtu.be/VIDEO_ID<br>
                            • https://www.youtube.com/embed/VIDEO_ID</small>
                        </li>
                        <li class="mb-2">
                            <strong>影片時長：</strong><br>
                            <small>格式：HH:MM:SS（如 01:30:45）或 MM:SS（如 90:45）</small>
                        </li>
                    </ul>

                    <hr />

                    <h6>範例：</h6>
                    <div class="alert alert-light">
                        <strong>課程：</strong> Python 基礎課程<br>
                        <strong>片段標題：</strong> 第一章 - 基礎介紹<br>
                        <strong>YouTube URL：</strong> https://www.youtube.com/watch?v=dQw4w9WgXcQ<br>
                        <strong>影片時長：</strong> 10:30
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 切換課程選擇模式
        function toggleLessionMainSelection() {
            const isNew = document.getElementById('radioNew').checked;
            const existingDiv = document.getElementById('existingLessionMainDiv');
            const newDiv = document.getElementById('newLessionMainDiv');
            const existingSelect = document.getElementById('LessionMainID');
            const newInput = document.getElementById('NewLessionMainName');

            if (isNew) {
                existingDiv.style.display = 'none';
                newDiv.style.display = 'block';
                if (existingSelect) existingSelect.value = '';
            } else {
                existingDiv.style.display = 'block';
                newDiv.style.display = 'none';
                if (newInput) newInput.value = '';
            }
        }

        // 從 YouTube URL 提取 Video ID
        function extractVideoId(url) {
            if (!url) return '';

            let videoId = '';
            
            if (url.includes('youtube.com/watch?v=')) {
                const startIndex = url.indexOf('watch?v=') + 8;
                const endIndex = url.indexOf('&', startIndex);
                videoId = endIndex === -1 
                    ? url.substring(startIndex) 
                    : url.substring(startIndex, endIndex);
            } else if (url.includes('youtu.be/')) {
                const startIndex = url.indexOf('youtu.be/') + 9;
                const endIndex = url.indexOf('?', startIndex);
                videoId = endIndex === -1 
                    ? url.substring(startIndex) 
                    : url.substring(startIndex, endIndex);
            } else if (url.includes('youtube.com/embed/')) {
                const startIndex = url.indexOf('embed/') + 6;
                const endIndex = url.indexOf('?', startIndex);
                videoId = endIndex === -1 
                    ? url.substring(startIndex) 
                    : url.substring(startIndex, endIndex);
            }

            return videoId;
        }

        // 預覽影片
        function previewVideo() {
            const url = document.getElementById('youtubeUrl').value;
            if (!url) {
                Swal.fire({
                    title: '提示',
                    text: '請先輸入 YouTube URL',
                    icon: 'warning',
                    confirmButtonText: '確定'
                });
                return;
            }

            const videoId = extractVideoId(url);
            if (!videoId) {
                Swal.fire({
                    title: '錯誤',
                    text: '無法識別 YouTube URL，請確認格式正確',
                    icon: 'error',
                    confirmButtonText: '確定'
                });
                return;
            }

            const previewDiv = document.getElementById('videoPreview');
            const iframe = document.getElementById('previewIframe');
            iframe.src = `https://www.youtube.com/embed/${videoId}?enablejsapi=1`;
            previewDiv.style.display = 'block';

            // 滾動到預覽區域
            previewDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // 自動取得影片長度
        async function fetchVideoDuration() {
            const url = document.getElementById('youtubeUrl').value;
            const durationInput = document.getElementById('urlTimeString');
            const statusSpan = document.getElementById('durationStatus');
            const btnFetch = document.getElementById('btnFetchDuration');

            if (!url) {
                Swal.fire({
                    title: '提示',
                    text: '請先輸入 YouTube URL',
                    icon: 'warning',
                    confirmButtonText: '確定'
                });
                return;
            }

            const videoId = extractVideoId(url);
            if (!videoId) {
                Swal.fire({
                    title: '錯誤',
                    text: '無法識別 YouTube URL，請確認格式正確',
                    icon: 'error',
                    confirmButtonText: '確定'
                });
                return;
            }

            // 顯示載入狀態
            btnFetch.disabled = true;
            btnFetch.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 取得中...';
            statusSpan.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 正在取得影片資訊...';
            statusSpan.className = 'ms-2 text-info';

            try {
                const response = await fetch('@Url.Action("GetYouTubeVideoInfo", "Lession")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    },
                    body: JSON.stringify({ url: url })
                });

                const data = await response.json();

                if (data.success) {
                    durationInput.value = data.duration;
                    statusSpan.innerHTML = '<i class="fas fa-check-circle text-success"></i> 已自動填入';
                    statusSpan.className = 'ms-2 text-success';
                    
                    Swal.fire({
                        title: '成功',
                        text: `已自動取得影片長度：${data.duration}`,
                        icon: 'success',
                        timer: 2000,
                        showConfirmButton: false
                    });
                } else {
                    statusSpan.innerHTML = '<i class="fas fa-exclamation-triangle text-warning"></i> ' + data.message;
                    statusSpan.className = 'ms-2 text-warning';
                    
                    Swal.fire({
                        title: '無法取得',
                        text: data.message || '無法取得影片長度，請手動輸入',
                        icon: 'warning',
                        confirmButtonText: '確定'
                    });
                }
            } catch (error) {
                statusSpan.innerHTML = '<i class="fas fa-times-circle text-danger"></i> 發生錯誤';
                statusSpan.className = 'ms-2 text-danger';
                
                Swal.fire({
                    title: '錯誤',
                    text: '無法連線到伺服器，請稍後再試',
                    icon: 'error',
                    confirmButtonText: '確定'
                });
            } finally {
                btnFetch.disabled = false;
                btnFetch.innerHTML = '<i class="fas fa-sync-alt"></i> 自動取得';
            }
        }

        // URL 輸入時自動驗證
        document.getElementById('youtubeUrl')?.addEventListener('blur', function() {
            const url = this.value;
            if (url) {
                const videoId = extractVideoId(url);
                if (!videoId) {
                    Swal.fire({
                        title: '警告',
                        text: '無法識別 YouTube URL 格式，請確認輸入正確',
                        icon: 'warning',
                        timer: 3000,
                        showConfirmButton: false
                    });
                } else {
                    // 清除之前的狀態
                    const statusSpan = document.getElementById('durationStatus');
                    if (statusSpan) {
                        statusSpan.innerHTML = '';
                        statusSpan.className = 'ms-2';
                    }
                }
            }
        });

        // 表單提交前驗證
        document.getElementById('createForm')?.addEventListener('submit', function(e) {
            const isNew = document.getElementById('radioNew').checked;
            const url = document.getElementById('youtubeUrl').value;

            // 驗證課程選擇
            if (!isNew) {
                const lessionMainID = document.getElementById('LessionMainID').value;
                if (!lessionMainID) {
                    e.preventDefault();
                    Swal.fire({
                        title: '錯誤',
                        text: '請選擇課程或建立新課程',
                        icon: 'error',
                        confirmButtonText: '確定'
                    });
                    return false;
                }
            } else {
                const newLessionMainName = document.getElementById('NewLessionMainName').value;
                if (!newLessionMainName || newLessionMainName.trim() === '') {
                    e.preventDefault();
                    Swal.fire({
                        title: '錯誤',
                        text: '請輸入新課程名稱',
                        icon: 'error',
                        confirmButtonText: '確定'
                    });
                    return false;
                }
            }

            // 驗證 YouTube URL
            if (url) {
                const videoId = extractVideoId(url);
                if (!videoId) {
                    e.preventDefault();
                    Swal.fire({
                        title: '錯誤',
                        text: '無法識別 YouTube URL，請確認格式正確',
                        icon: 'error',
                        confirmButtonText: '確定'
                    });
                    return false;
                }
            }
        });
    </script>
}
