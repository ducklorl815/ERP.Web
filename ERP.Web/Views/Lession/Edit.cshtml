@model LifeTech.ERP.Emanage.Web.Controllers.Lession.LessionEditViewModel
@{
    ViewData["Title"] = "修改課程片段";
}

<div class="container-fluid" style="margin-bottom: 100px; padding-bottom: 50px;">
    <div class="row">
        <div class="col-12">
            <h2>修改課程片段</h2>
            <hr />
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="fas fa-check-circle"></i> @TempData["SuccessMessage"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="row">
        <div class="col-lg-8 col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-edit"></i> 課程片段資訊</h5>
                </div>
                <div class="card-body">
                    <form asp-action="Edit" method="post" id="editForm">
                        @Html.AntiForgeryToken()
                        <input type="hidden" asp-for="ID" />

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- 課程選擇 -->
                        <div class="card mb-3">
                            <div class="card-header bg-info text-white">
                                <h3 class="mb-0"><i class="fas fa-book"></i> 選擇課程</h3>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="LessionMainID" class="form-label"></label>
                                    <select asp-for="LessionMainID" asp-items="Model.LessionMainList" class="form-select">
                                        <option value="">-- 請選擇課程 --</option>
                                    </select>
                                    <span asp-validation-for="LessionMainID" class="text-danger"></span>
                                    <small class="form-text text-muted">可以選擇不同的課程來調整片段所屬的課程</small>
                                </div>
                            </div>
                        </div>

                        <!-- 片段基本資訊 -->
                        <div class="card mb-3">
                            <div class="card-header">
                                <h3 class="mb-0"><i class="fas fa-video"></i> 片段基本資訊</h3>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="Title" class="form-label"></label>
                                    <input asp-for="Title" class="form-control" placeholder="例如: 第一章 - 基礎介紹" />
                                    <span asp-validation-for="Title" class="text-danger"></span>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="Content" class="form-label"></label>
                                    <textarea asp-for="Content" class="form-control" rows="3" placeholder="片段內容描述..."></textarea>
                                    <span asp-validation-for="Content" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <!-- YouTube 影片資訊 -->
                        <div class="card mb-3">
                            <div class="card-header bg-primary text-white">
                                <h3 class="mb-0"><i class="fab fa-youtube"></i> YouTube 影片資訊</h3>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="URL" class="form-label"></label>
                                    <input asp-for="URL" class="form-control" 
                                           placeholder="https://www.youtube.com/watch?v=VIDEO_ID 或 https://youtu.be/VIDEO_ID" 
                                           id="youtubeUrl" />
                                    <span asp-validation-for="URL" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        支援格式：youtube.com/watch?v=, youtu.be/, youtube.com/embed/
                                    </small>
                                </div>

                                <div class="mb-3">
                                    <label asp-for="URLTimeString" class="form-label"></label>
                                    <div class="input-group">
                                        <input asp-for="URLTimeString" class="form-control" 
                                               placeholder="例如: 10:30 或 00:10:30" 
                                               id="urlTimeString" />
                                        <button type="button" class="btn btn-outline-secondary" id="btnFetchDuration" onclick="fetchVideoDuration()">
                                            <i class="fas fa-sync-alt"></i> 自動取得
                                        </button>
                                    </div>
                                    <span asp-validation-for="URLTimeString" class="text-danger"></span>
                                    <small class="form-text text-muted">
                                        格式：HH:MM:SS（如 01:30:45）或 MM:SS（如 90:45）
                                        <span id="durationStatus" class="ms-2"></span>
                                    </small>
                                </div>

                                <!-- 預覽區域 -->
                                <div id="videoPreview" class="mb-3" style="display: none;">
                                    <div class="card">
                                        <div class="card-body">
                                            <h3 class="card-title">影片預覽</h3>
                                            <div class="embed-responsive embed-responsive-16by9" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
                                                <iframe id="previewIframe" 
                                                        style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"
                                                        frameborder="0" 
                                                        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
                                                        allowfullscreen>
                                                </iframe>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>

                        <!-- 圖片設定 -->
                        <div class="card mb-3">
                            <div class="card-header">
                                <h3 class="mb-0"><i class="fas fa-image"></i> 圖片設定（選填）</h3>
                            </div>
                            <div class="card-body">
                                <div class="mb-3">
                                    <label asp-for="Img" class="form-label"></label>
                                    <input asp-for="Img" class="form-control" placeholder="https://example.com/image.jpg" />
                                    <span asp-validation-for="Img" class="text-danger"></span>
                                    <small class="form-text text-muted">課程列表顯示的封面圖片</small>
                                </div>
                            </div>
                        </div>

                        <!-- 影片標籤/錨點管理 -->
                        <div class="card mb-3">
                            <div class="card-header bg-primary text-white">
                                <h3 class="mb-0"><i class="fas fa-tags"></i> 影片標籤/錨點管理</h3>
                            </div>
                            <div class="card-body">
                                <p class="text-muted small mb-3">
                                    <i class="fas fa-info-circle"></i> 可以為影片添加時間點標籤，類似 YouTube 的章節功能。點擊標籤可快速跳轉到對應時間點。
                                </p>
                                <div id="tagContainer">
                                    <!-- 標籤列表將動態生成 -->
                                </div>
                                <button type="button" class="btn btn-sm btn-success mt-2" onclick="addTag()">
                                    <i class="fas fa-plus"></i> 新增標籤
                                </button>
                                <input type="hidden" asp-for="TagJson" id="TagJson" />
                            </div>
                        </div>

                        <!-- 操作按鈕 -->
                        <div class="d-flex justify-content-between">
                            <a href="@Url.Action("Index", "Lession")" class="btn btn-secondary">
                                <i class="fas fa-arrow-left"></i> 返回列表
                            </a>
                            <div>
                                <button type="button" class="btn btn-info" onclick="previewVideo()">
                                    <i class="fas fa-eye"></i> 預覽影片
                                </button>
                                @if (Model.LessionMainID.HasValue)
                                {
                                    <a href="@Url.Action("Create", "Lession", new { lessionMainID = Model.LessionMainID.Value })" class="btn btn-success">
                                        <i class="fas fa-plus"></i> 新增下一個片段
                                    </a>
                                }
                                <button type="submit" class="btn btn-primary">
                                    <i class="fas fa-save"></i> 儲存修改
                                </button>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- 右側：說明 -->
        <div class="col-lg-4 col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0"><i class="fas fa-info-circle"></i> 使用說明</h5>
                </div>
                <div class="card-body">
                    <h3>修改說明：</h3>
                    <ul class="list-unstyled">
                        <li class="mb-2">
                            <strong>選擇課程：</strong><br>
                            <small>可以選擇不同的課程來調整片段所屬的課程，系統會自動更新課程的片段列表</small>
                        </li>
                        <li class="mb-2">
                            <strong>片段標題：</strong><br>
                            <small>此片段的標題，會顯示在播放清單中，修改後會同步更新到課程的片段列表</small>
                        </li>
                        <li class="mb-2">
                            <strong>YouTube URL：</strong><br>
                            <small>支援多種格式：<br>
                            • https://www.youtube.com/watch?v=VIDEO_ID<br>
                            • https://youtu.be/VIDEO_ID<br>
                            • https://www.youtube.com/embed/VIDEO_ID</small>
                        </li>
                        <li class="mb-2">
                            <strong>影片時長：</strong><br>
                            <small>格式：HH:MM:SS（如 01:30:45）或 MM:SS（如 90:45）</small>
                        </li>
                    </ul>

                    <hr />

                    <div class="alert alert-warning">
                        <i class="fas fa-exclamation-triangle"></i>
                        <strong>注意事項：</strong><br>
                        <small>修改片段所屬課程時，系統會自動從原課程移除並加入到新課程中。</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script>
        // 從 YouTube URL 提取 Video ID
        function extractVideoId(url) {
            if (!url) return '';

            let videoId = '';
            
            if (url.includes('youtube.com/watch?v=')) {
                const startIndex = url.indexOf('watch?v=') + 8;
                const endIndex = url.indexOf('&', startIndex);
                videoId = endIndex === -1 
                    ? url.substring(startIndex) 
                    : url.substring(startIndex, endIndex);
            } else if (url.includes('youtu.be/')) {
                const startIndex = url.indexOf('youtu.be/') + 9;
                const endIndex = url.indexOf('?', startIndex);
                videoId = endIndex === -1 
                    ? url.substring(startIndex) 
                    : url.substring(startIndex, endIndex);
            } else if (url.includes('youtube.com/embed/')) {
                const startIndex = url.indexOf('embed/') + 6;
                const endIndex = url.indexOf('?', startIndex);
                videoId = endIndex === -1 
                    ? url.substring(startIndex) 
                    : url.substring(startIndex, endIndex);
            }

            return videoId;
        }

        // 預覽影片
        function previewVideo() {
            const url = document.getElementById('youtubeUrl').value;
            if (!url) {
                Swal.fire({
                    title: '提示',
                    text: '請先輸入 YouTube URL',
                    icon: 'warning',
                    confirmButtonText: '確定'
                });
                return;
            }

            const videoId = extractVideoId(url);
            if (!videoId) {
                Swal.fire({
                    title: '錯誤',
                    text: '無法識別 YouTube URL，請確認格式正確',
                    icon: 'error',
                    confirmButtonText: '確定'
                });
                return;
            }

            const previewDiv = document.getElementById('videoPreview');
            const iframe = document.getElementById('previewIframe');
            iframe.src = `https://www.youtube.com/embed/${videoId}?enablejsapi=1`;
            previewDiv.style.display = 'block';

            // 滾動到預覽區域
            previewDiv.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
        }

        // YouTube Player 變數
        let youtubePlayer = null;
        let isYouTubeAPIReady = false;

        // 載入 YouTube iframe API
        if (typeof YT === 'undefined') {
            var tag = document.createElement('script');
            tag.src = "https://www.youtube.com/iframe_api";
            var firstScriptTag = document.getElementsByTagName('script')[0];
            firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);
        }

        // YouTube API 準備就緒回調
        function onYouTubeIframeAPIReady() {
            isYouTubeAPIReady = true;
        }

        // 將秒數轉換為時間字串格式（HH:MM:SS 或 MM:SS）
        function formatTimeSpan(totalSeconds) {
            const hours = Math.floor(totalSeconds / 3600);
            const minutes = Math.floor((totalSeconds % 3600) / 60);
            const seconds = totalSeconds % 60;

            if (hours > 0) {
                return `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            } else {
                return `${minutes.toString().padStart(2, '0')}:${seconds.toString().padStart(2, '0')}`;
            }
        }

        // 自動取得影片長度（使用 YouTube iframe API）
        function fetchVideoDuration() {
            const url = document.getElementById('youtubeUrl').value;
            const durationInput = document.getElementById('urlTimeString');
            const statusSpan = document.getElementById('durationStatus');
            const btnFetch = document.getElementById('btnFetchDuration');

            if (!url) {
                Swal.fire({
                    title: '提示',
                    text: '請先輸入 YouTube URL',
                    icon: 'warning',
                    confirmButtonText: '確定'
                });
                return;
            }

            const videoId = extractVideoId(url);
            if (!videoId) {
                Swal.fire({
                    title: '錯誤',
                    text: '無法識別 YouTube URL，請確認格式正確',
                    icon: 'error',
                    confirmButtonText: '確定'
                });
                return;
            }

            // 顯示載入狀態
            btnFetch.disabled = true;
            btnFetch.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 取得中...';
            statusSpan.innerHTML = '<i class="fas fa-spinner fa-spin"></i> 正在取得影片資訊...';
            statusSpan.className = 'ms-2 text-info';

            // 確保 YouTube API 已載入
            if (typeof YT === 'undefined' || typeof YT.Player === 'undefined') {
                // 如果 API 還沒載入，等待載入完成
                const checkAPI = setInterval(() => {
                    if (typeof YT !== 'undefined' && typeof YT.Player !== 'undefined') {
                        clearInterval(checkAPI);
                        loadVideoDuration(videoId, durationInput, statusSpan, btnFetch);
                    }
                }, 100);

                // 10秒超時
                setTimeout(() => {
                    clearInterval(checkAPI);
                    if (typeof YT === 'undefined' || typeof YT.Player === 'undefined') {
                        btnFetch.disabled = false;
                        btnFetch.innerHTML = '<i class="fas fa-sync-alt"></i> 自動取得';
                        statusSpan.innerHTML = '<i class="fas fa-times-circle text-danger"></i> YouTube API 載入失敗';
                        statusSpan.className = 'ms-2 text-danger';
                        Swal.fire({
                            title: '錯誤',
                            text: 'YouTube API 載入失敗，請重新整理頁面後再試',
                            icon: 'error',
                            confirmButtonText: '確定'
                        });
                    }
                }, 10000);
            } else {
                loadVideoDuration(videoId, durationInput, statusSpan, btnFetch);
            }
        }

        // 使用 YouTube Player 載入影片並取得時長
        function loadVideoDuration(videoId, durationInput, statusSpan, btnFetch) {
            try {
                // 如果已有 player，先銷毀
                if (youtubePlayer) {
                    youtubePlayer.destroy();
                }

                // 創建臨時的隱藏 div 來載入 player
                const tempDiv = document.createElement('div');
                tempDiv.id = 'temp-youtube-player';
                tempDiv.style.display = 'none';
                document.body.appendChild(tempDiv);

                // 創建 YouTube Player
                youtubePlayer = new YT.Player('temp-youtube-player', {
                    videoId: videoId,
                    events: {
                        'onReady': function(event) {
                            try {
                                const duration = event.target.getDuration();
                                if (duration && duration > 0) {
                                    const timeString = formatTimeSpan(duration);
                                    durationInput.value = timeString;
                                    statusSpan.innerHTML = '<i class="fas fa-check-circle text-success"></i> 已自動填入';
                                    statusSpan.className = 'ms-2 text-success';
                                    
                                    Swal.fire({
                                        title: '成功',
                                        text: `已自動取得影片長度：${timeString}`,
                                        icon: 'success',
                                        timer: 2000,
                                        showConfirmButton: false
                                    });

                                    // 清理臨時元素
                                    if (youtubePlayer) {
                                        youtubePlayer.destroy();
                                        youtubePlayer = null;
                                    }
                                    if (tempDiv && tempDiv.parentNode) {
                                        tempDiv.parentNode.removeChild(tempDiv);
                                    }
                                } else {
                                    throw new Error('無法取得影片時長');
                                }
                            } catch (error) {
                                statusSpan.innerHTML = '<i class="fas fa-exclamation-triangle text-warning"></i> 無法取得影片時長';
                                statusSpan.className = 'ms-2 text-warning';
                                
                                Swal.fire({
                                    title: '無法取得',
                                    text: '無法取得影片長度，請手動輸入',
                                    icon: 'warning',
                                    confirmButtonText: '確定'
                                });

                                // 清理臨時元素
                                if (youtubePlayer) {
                                    youtubePlayer.destroy();
                                    youtubePlayer = null;
                                }
                                if (tempDiv && tempDiv.parentNode) {
                                    tempDiv.parentNode.removeChild(tempDiv);
                                }
                            } finally {
                                btnFetch.disabled = false;
                                btnFetch.innerHTML = '<i class="fas fa-sync-alt"></i> 自動取得';
                            }
                        },
                        'onError': function(event) {
                            statusSpan.innerHTML = '<i class="fas fa-exclamation-triangle text-warning"></i> 無法載入影片';
                            statusSpan.className = 'ms-2 text-warning';
                            
                            Swal.fire({
                                title: '無法取得',
                                text: '無法載入影片，請確認 URL 是否正確或手動輸入時長',
                                icon: 'warning',
                                confirmButtonText: '確定'
                            });

                            // 清理臨時元素
                            if (youtubePlayer) {
                                youtubePlayer.destroy();
                                youtubePlayer = null;
                            }
                            if (tempDiv && tempDiv.parentNode) {
                                tempDiv.parentNode.removeChild(tempDiv);
                            }

                            btnFetch.disabled = false;
                            btnFetch.innerHTML = '<i class="fas fa-sync-alt"></i> 自動取得';
                        }
                    }
                });
            } catch (error) {
                statusSpan.innerHTML = '<i class="fas fa-times-circle text-danger"></i> 發生錯誤';
                statusSpan.className = 'ms-2 text-danger';
                
                Swal.fire({
                    title: '錯誤',
                    text: '發生錯誤：' + error.message,
                    icon: 'error',
                    confirmButtonText: '確定'
                });

                btnFetch.disabled = false;
                btnFetch.innerHTML = '<i class="fas fa-sync-alt"></i> 自動取得';
            }
        }

        // 全域回調函數（YouTube API 需要）
        window.onYouTubeIframeAPIReady = onYouTubeIframeAPIReady;

        // URL 輸入時自動驗證
        document.getElementById('youtubeUrl')?.addEventListener('blur', function() {
            const url = this.value;
            if (url) {
                const videoId = extractVideoId(url);
                if (!videoId) {
                    Swal.fire({
                        title: '警告',
                        text: '無法識別 YouTube URL 格式，請確認輸入正確',
                        icon: 'warning',
                        timer: 3000,
                        showConfirmButton: false
                    });
                } else {
                    // 清除之前的狀態
                    const statusSpan = document.getElementById('durationStatus');
                    if (statusSpan) {
                        statusSpan.innerHTML = '';
                        statusSpan.className = 'ms-2';
                    }
                }
            }
        });

        // 表單提交前驗證
        document.getElementById('editForm')?.addEventListener('submit', function(e) {
            const lessionMainID = document.getElementById('LessionMainID').value;
            const url = document.getElementById('youtubeUrl').value;

            // 驗證課程選擇
            if (!lessionMainID) {
                e.preventDefault();
                Swal.fire({
                    title: '錯誤',
                    text: '請選擇課程',
                    icon: 'error',
                    confirmButtonText: '確定'
                });
                return false;
            }

            // 驗證 YouTube URL
            if (url) {
                const videoId = extractVideoId(url);
                if (!videoId) {
                    e.preventDefault();
                    Swal.fire({
                        title: '錯誤',
                        text: '無法識別 YouTube URL，請確認格式正確',
                        icon: 'error',
                        confirmButtonText: '確定'
                    });
                    return false;
                }
            }
            // 保存標籤數據到隱藏欄位
            saveTagsToJson();
        });

        // 標籤管理功能
        let tagIndex = 0;
        let tags = [];

        // 初始化標籤（如果有現有數據）
        function initTags() {
            const tagJson = document.getElementById('TagJson').value;
            if (tagJson) {
                try {
                    tags = JSON.parse(tagJson);
                    tags.forEach((tag, index) => {
                        addTagToUI(tag.Time, tag.Title, index);
                    });
                    tagIndex = tags.length;
                } catch (e) {
                    console.error('解析標籤 JSON 失敗:', e);
                }
            }
        }

        // 新增標籤
        function addTag() {
            addTagToUI(0, '', tagIndex++);
        }

        // 添加標籤到 UI
        function addTagToUI(time, title, index) {
            const container = document.getElementById('tagContainer');
            const tagDiv = document.createElement('div');
            tagDiv.className = 'tag-item mb-2 p-2 border rounded';
            tagDiv.dataset.index = index;
            tagDiv.innerHTML = `
                <div class="row g-2 align-items-center">
                    <div class="col-md-4">
                        <label class="form-label small mb-0">時間點（秒）</label>
                        <input type="number" class="form-control form-control-sm tag-time" 
                               value="${time}" min="0" 
                               onchange="updateTag(${index})" 
                               placeholder="例如：60">
                    </div>
                    <div class="col-md-6">
                        <label class="form-label small mb-0">標籤標題（中文）</label>
                        <input type="text" class="form-control form-control-sm tag-title" 
                               value="${title}" 
                               onchange="updateTag(${index})" 
                               placeholder="例如：第一章 基礎介紹">
                    </div>
                    <div class="col-md-2">
                        <label class="form-label small mb-0">&nbsp;</label>
                        <button type="button" class="btn btn-sm btn-danger w-100" 
                                onclick="removeTag(${index})">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                </div>
            `;
            container.appendChild(tagDiv);
            if (index >= tags.length) {
                tags.push({ Time: time, Title: title });
            }
        }

        // 更新標籤
        function updateTag(index) {
            const tagDiv = document.querySelector(`.tag-item[data-index="${index}"]`);
            if (tagDiv) {
                const timeInput = tagDiv.querySelector('.tag-time');
                const titleInput = tagDiv.querySelector('.tag-title');
                const time = parseInt(timeInput.value) || 0;
                const title = titleInput.value.trim();
                
                if (tags[index]) {
                    tags[index].Time = time;
                    tags[index].Title = title;
                } else {
                    tags[index] = { Time: time, Title: title };
                }
                saveTagsToJson();
            }
        }

        // 移除標籤
        function removeTag(index) {
            const tagDiv = document.querySelector(`.tag-item[data-index="${index}"]`);
            if (tagDiv) {
                tagDiv.remove();
                tags.splice(index, 1);
                // 重新渲染所有標籤
                const container = document.getElementById('tagContainer');
                container.innerHTML = '';
                tags.forEach((tag, i) => {
                    addTagToUI(tag.Time, tag.Title, i);
                });
                tagIndex = tags.length;
                saveTagsToJson();
            }
        }

        // 保存標籤到 JSON
        function saveTagsToJson() {
            // 過濾掉空的標籤
            const validTags = tags.filter(tag => tag.Title && tag.Title.trim() !== '');
            // 按時間排序
            validTags.sort((a, b) => a.Time - b.Time);
            document.getElementById('TagJson').value = JSON.stringify(validTags);
        }

        // 頁面載入時初始化
        document.addEventListener('DOMContentLoaded', function() {
            initTags();
        });
    </script>
}

