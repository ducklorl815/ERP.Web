@model ERP.Web.Controllers.Lession.LessionIndexViewModel
@{
    ViewData["Title"] = "課程列表";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0">課程列表</h2>
            <a href="@Url.Action("Create", "Lession")" class="btn btn-primary">
                <i class="fas fa-plus"></i> 新增課程
            </a>
        </div>
    </div>
    <hr />

    <div class="row">
        @foreach (var lessionMainProgress in Model.LessionMainProgressList)
        {
            var progress = lessionMainProgress;
            var lessionMain = progress.LessionMain;

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title">@lessionMain.LessionName</h5>
                        <p class="card-text text-muted small">
                            <i class="fas fa-list"></i> 共 @progress.TotalSegments 個片段
                        </p>
                        
                        @if (progress.TotalSegments > 0)
                        {
                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted">觀看進度</small>
                                    <small class="text-muted">@progress.ProgressPercentage%</small>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar @(progress.IsCompleted ? "bg-success" : "bg-primary")" 
                                         role="progressbar" 
                                         style="width: @progress.ProgressPercentage%" 
                                         aria-valuenow="@progress.ProgressPercentage" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                                <div class="mt-1">
                                    <small class="text-muted">
                                        已完成：@progress.CompletedSegments / @progress.TotalSegments 個片段
                                    </small>
                                </div>
                            </div>
                            
                            @if (progress.IsCompleted)
                            {
                                <span class="badge bg-success mb-2">已完成</span>
                            }
                            else if (progress.ProgressPercentage > 0)
                            {
                                <span class="badge bg-warning mb-2">進行中</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary mb-2">未開始</span>
                            }
                        }
                        else
                        {
                            <div class="alert alert-warning mb-2" style="padding: 0.5rem;">
                                <small><i class="fas fa-exclamation-triangle"></i> 此課程尚未設定片段</small>
                            </div>
                        }
                    </div>
                    <div class="card-footer">
                        @if (progress.TotalSegments > 0)
                        {
                            <a href="@Url.Action("PlayMultiSegment", "Lession", new { lessionMainID = lessionMain.ID, employeeMainID = Model.EmployeeMainID })" 
                               class="btn btn-primary w-100">
                                @if (progress.IsCompleted)
                                {
                                    <i class="fas fa-redo">重新觀看</i> 
                                }
                                else if (progress.ProgressPercentage > 0)
                                {
                                    <i class="fas fa-play">繼續觀看</i> 
                                }
                                else
                                {
                                    <i class="fas fa-play">開始觀看</i> 
                                }
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary w-100" disabled>
                                <i class="fas fa-lock"></i> 無法觀看（無片段）
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.LessionMainProgressList.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> 目前沒有可用的課程。
        </div>
    }
</div>
