@model ERP.Web.Service.ViewModels.LessionIndexViewModel
@{
    ViewData["Title"] = "課程列表";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0">課程列表</h2>
        </div>
    </div>
    <hr />

    <div class="row">
        @foreach (var lessionMainProgress in Model.LessionMainProgressList)
        {
            var progress = lessionMainProgress;
            var lessionMain = progress.LessionMain;

            <div class="col-md-6 col-lg-4 mb-4">
                <div class="card h-100">
                    <div class="card-body">
                        <h5 class="card-title" style="font-size: 1.25rem; font-weight: 600;">@lessionMain.LessionName</h5>
                        <p class="card-text text-muted" style="font-size: 0.95rem;">
                            <i class="fas fa-list"></i> 共 @progress.TotalSegments 個片段
                        </p>
                        
                        @if (progress.TotalSegments > 0)
                        {
                            <div class="mb-2">
                                <div class="d-flex justify-content-between align-items-center mb-1">
                                    <small class="text-muted" style="font-size: 0.9rem;">觀看進度</small>
                                    <small class="text-muted" style="font-size: 0.9rem;">@progress.ProgressPercentage%</small>
                                </div>
                                <div class="progress" style="height: 8px;">
                                    <div class="progress-bar @(progress.IsCompleted ? "bg-success" : "bg-primary")" 
                                         role="progressbar" 
                                         style="width: @progress.ProgressPercentage%" 
                                         aria-valuenow="@progress.ProgressPercentage" 
                                         aria-valuemin="0" 
                                         aria-valuemax="100">
                                    </div>
                                </div>
                                <div class="mt-1">
                                    <small class="text-muted" style="font-size: 0.9rem;">
                                        已完成：@progress.CompletedSegments / @progress.TotalSegments 個片段
                                    </small>
                                </div>
                            </div>
                            
                            @if (progress.IsCompleted)
                            {
                                <span class="badge bg-success mb-2" style="font-size: 0.9rem;">已完成</span>
                            }
                            else if (progress.ProgressPercentage > 0)
                            {
                                <span class="badge bg-warning mb-2" style="font-size: 0.9rem;">進行中</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary mb-2 text-white" style="font-size: 0.9rem;">未開始</span>
                            }
                        }
                        else
                        {
                            <div class="alert alert-warning mb-2" style="padding: 0.5rem;">
                                <small><i class="fas fa-exclamation-triangle"></i> 此課程尚未設定片段</small>
                            </div>
                        }
                    </div>
                    <div class="card-footer" style="padding: 1rem;">
                        @if (progress.TotalSegments > 0)
                        {
                            <a href="@Url.Action("PlayMultiSegment", "Lession", new { lessionMainID = lessionMain.ID })" 
                               class="btn btn-primary w-100" style="font-size: 1rem; padding: 0.75rem;">
                                @if (progress.IsCompleted)
                                {
                                    <i class="fas fa-redo me-2"></i><span>  重新觀看</span>
                                }
                                else if (progress.ProgressPercentage > 0)
                                {
                                    <i class="fas fa-play me-2"></i><span>  繼續觀看</span>
                                }
                                else
                                {
                                    <i class="fas fa-play me-2"></i><span>  開始觀看</span>
                                }
                            </a>
                        }
                        else
                        {
                            <button class="btn btn-secondary w-100" disabled style="font-size: 1rem; padding: 0.75rem;">
                                <i class="fas fa-lock me-2"></i><span>無法觀看（無片段）</span>
                            </button>
                        }
                    </div>
                </div>
            </div>
        }
    </div>

    @if (!Model.LessionMainProgressList.Any())
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> 目前沒有可用的課程。
        </div>
    }
</div>
