@model ERP.Web.Controllers.Lession.LessionMultiSegmentViewModel
@{
    ViewData["Title"] = $"課程分頁 {Model.Page} - 多片段播放";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12">
            <h2>課程分頁 @Model.Page - 多片段播放</h2>
            <hr />
        </div>
    </div>

    <div class="row">
        <!-- 左側：主要播放區域 -->
        <div class="col-lg-8 col-md-12 mb-4">
            <div class="card">
                <div class="card-body">
                    <!-- 當前播放片段的標題和描述 -->
                    <div id="currentSegmentInfo">
                        @{
                            var firstSegment = Model.Segments.First();
                            var firstProgress = Model.ProgressDict.ContainsKey(firstSegment.ID) ? Model.ProgressDict[firstSegment.ID] : null;
                        }
                        <h5 class="card-title" id="currentTitle" style="@firstSegment.TitleStyle">@firstSegment.Title</h5>
                        <p class="card-text" id="currentContent" style="@firstSegment.ContentStyle">@firstSegment.Content</p>
                    </div>

                    <!-- YouTube 影片播放器容器（只顯示一個） -->
                    <div class="embed-responsive embed-responsive-16by9 mb-3" style="position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden;">
                        <div id="mainVideoPlayer" style="position: absolute; top: 0; left: 0; width: 100%; height: 100%;"></div>
                    </div>

                    <!-- 進度條 -->
                    <div class="mb-3">
                        <div class="d-flex justify-content-between align-items-center mb-2">
                            <span>觀看進度</span>
                            <span id="mainProgressText">0%</span>
                        </div>
                        <div class="progress" style="height: 20px;">
                            <div id="mainVideoBar" 
                                 class="progress-bar" 
                                 role="progressbar" 
                                 style="width: 0%" 
                                 aria-valuenow="0" 
                                 aria-valuemin="0" 
                                 aria-valuemax="100">
                            </div>
                        </div>
                        <div class="mt-2">
                            <small class="text-muted">
                                已觀看：<span id="mainWatchedTime">00:00:00</span> / 
                                總時長：<span id="mainTotalTime">00:00:00</span>
                            </small>
                        </div>
                    </div>

                    <!-- 倒數計時 -->
                    <div class="mb-3">
                        <div class="card">
                            <div class="card-body">
                                <h6 class="card-title">剩餘觀看時間</h6>
                                <div class="d-flex justify-content-center align-items-center">
                                    <span id="mainCountdown_Hours" class="fs-3 fw-bold">00</span>
                                    <span class="fs-3 mx-2">:</span>
                                    <span id="mainCountdown_Minutes" class="fs-3 fw-bold">00</span>
                                    <span class="fs-3 mx-2">:</span>
                                    <span id="mainCountdown_Seconds" class="fs-3 fw-bold">00</span>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- 完成狀態和操作按鈕 -->
                    <div class="mb-3 d-flex justify-content-between align-items-center">
                        <div class="form-check">
                            <input class="form-check-input" 
                                   type="checkbox" 
                                   id="mainIsCompleted">
                            <label class="form-check-label" for="mainIsCompleted">
                                標記為已完成
                            </label>
                        </div>
                        <button type="button" 
                                class="btn btn-warning btn-sm" 
                                id="mainResetBtn"
                                onclick="resetCurrentProgress()">
                            <i class="fas fa-redo"></i> 重看此片段
                        </button>
                    </div>
                </div>
            </div>

            <!-- 返回按鈕 -->
            <div class="mt-3">
                <a href="@Url.Action("Index", "Lession", new { employeeMainID = Model.EmployeeMainID })" 
                   class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> 返回課程列表
                </a>
            </div>
        </div>

        <!-- 右側：播放清單 -->
        <div class="col-lg-4 col-md-12">
            <div class="card">
                <div class="card-header">
                    <h5 class="mb-0">
                        <i class="fas fa-list"></i> 播放清單
                        <span class="badge bg-primary ms-2">@Model.Segments.Count 個片段</span>
                    </h5>
                </div>
                <div class="card-body p-0">
                    <div class="list-group list-group-flush" id="playlistContainer" style="max-height: 80vh; overflow-y: auto;">
                        @for (int i = 0; i < Model.Segments.Count; i++)
                        {
                            var segment = Model.Segments[i];
                            var progress = Model.ProgressDict.ContainsKey(segment.ID) ? Model.ProgressDict[segment.ID] : null;
                            var watchedTime = progress?.Time ?? TimeSpan.Zero;
                            var isCompleted = progress?.State ?? false;
                            var watchedTimeSeconds = (int)watchedTime.TotalSeconds;
                            var totalTimeSeconds = (int)segment.URLTime.TotalSeconds;
                            var progressPercentage = totalTimeSeconds > 0 ? (int)((watchedTimeSeconds / (double)totalTimeSeconds) * 100) : 0;
                            var isActive = i == 0;
                            var playerId = $"VideoPlayer_{segment.MyModal}";
                            var timeSpanId = $"TimeSpan_myModal{segment.MyModal}";
                            var videoBarId = $"vedioBar_myModal{segment.MyModal}";

                            <div class="list-group-item list-group-item-action playlist-item @(isActive ? "active" : "")" 
                                 data-segment-index="@i"
                                 data-segment-id="@segment.ID"
                                 data-my-modal="@segment.MyModal"
                                 onclick="switchToSegment(@i, '@segment.ID', '@segment.MyModal')"
                                 style="cursor: pointer;">
                                <div class="d-flex w-100 justify-content-between align-items-start">
                                    <div class="flex-grow-1">
                                        <div class="d-flex align-items-center mb-2">
                                            @if (isCompleted)
                                            {
                                                <i class="fas fa-check-circle text-success me-2"></i>
                                            }
                                            else if (progress != null)
                                            {
                                                <i class="fas fa-play-circle text-warning me-2"></i>
                                            }
                                            else
                                            {
                                                <i class="fas fa-circle text-secondary me-2"></i>
                                            }
                                            <h6 class="mb-0" style="@segment.TitleStyle">@segment.Title</h6>
                                        </div>
                                        <p class="mb-2 small text-muted" style="@segment.ContentStyle">@segment.Content</p>
                                        <div class="progress mb-2" style="height: 4px;">
                                            <div class="progress-bar @(isCompleted ? "bg-success" : progress != null ? "bg-warning" : "bg-secondary")" 
                                                 role="progressbar" 
                                                 style="width: @progressPercentage%" 
                                                 aria-valuenow="@progressPercentage" 
                                                 aria-valuemin="0" 
                                                 aria-valuemax="100">
                                            </div>
                                        </div>
                                        <small class="text-muted">
                                            <i class="fas fa-clock"></i> 
                                            @segment.URLTime.ToString(@"mm\:ss") | 
                                            進度: @progressPercentage%
                                        </small>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- 隱藏的播放器容器（所有片段） -->
<div style="display: none;">
    @for (int i = 0; i < Model.Segments.Count; i++)
    {
        var segment = Model.Segments[i];
        var progress = Model.ProgressDict.ContainsKey(segment.ID) ? Model.ProgressDict[segment.ID] : null;
        var watchedTime = progress?.Time ?? TimeSpan.Zero;
        var watchedTimeSeconds = (int)watchedTime.TotalSeconds;
        var totalTimeSeconds = (int)segment.URLTime.TotalSeconds;
        var playerId = $"VideoPlayer_{segment.MyModal}";
        var timeSpanId = $"TimeSpan_myModal{segment.MyModal}";
        var videoBarId = $"vedioBar_myModal{segment.MyModal}";

        <div id="@playerId" 
             data-video="@GetYouTubeVideoId(segment.URL)" 
             data-watchtime="@watchedTimeSeconds"
             data-urltimesec="@totalTimeSeconds"
             data-url="@segment.URL"
             data-segment-id="@segment.ID"
             data-my-modal="@segment.MyModal"
             data-title="@segment.Title"
             data-content="@segment.Content"
             data-title-style="@segment.TitleStyle"
             data-content-style="@segment.ContentStyle"
             data-total-time="@segment.URLTime.ToString(@"hh\:mm\:ss")">
        </div>
    }
</div>

@functions {
    /// <summary>
    /// 從 YouTube URL 中提取 Video ID
    /// </summary>
    string GetYouTubeVideoId(string url)
    {
        if (string.IsNullOrEmpty(url))
            return string.Empty;

        string videoId = string.Empty;
        
        if (url.Contains("youtube.com/watch?v="))
        {
            var startIndex = url.IndexOf("watch?v=") + 8;
            var endIndex = url.IndexOf("&", startIndex);
            if (endIndex == -1) endIndex = url.Length;
            videoId = url.Substring(startIndex, endIndex - startIndex);
        }
        else if (url.Contains("youtu.be/"))
        {
            var startIndex = url.IndexOf("youtu.be/") + 9;
            var endIndex = url.IndexOf("?", startIndex);
            if (endIndex == -1) endIndex = url.Length;
            videoId = url.Substring(startIndex, endIndex - startIndex);
        }
        else if (url.Contains("youtube.com/embed/"))
        {
            var startIndex = url.IndexOf("embed/") + 6;
            var endIndex = url.IndexOf("?", startIndex);
            if (endIndex == -1) endIndex = url.Length;
            videoId = url.Substring(startIndex, endIndex - startIndex);
        }

        return videoId;
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <style>
        .playlist-item {
            transition: background-color 0.2s;
        }
        .playlist-item:hover {
            background-color: #f8f9fa;
        }
        .playlist-item.active {
            background-color: #e7f3ff;
            border-left: 4px solid #0d6efd;
        }
    </style>
    <script>
        // 全域變數
        const employeeMainID = '@Model.EmployeeMainID';
        const empsplitMainID = employeeMainID.split("-")[3];
        const countdownTimers = [];
        const videoPlayers = [];
        let mainCountdown = null;
        let currentPlayer = null;
        let currentSegmentIndex = 0;
        let mainPlayerInstance = null;

        // 主要倒數計時器類別
        class MainCountdown {
            constructor(totalSeconds) {
                this.totalSeconds = totalSeconds;
                this.intervalId = null;
                this.isRunning = false;
            }

            start() {
                this.stop();
                this.isRunning = true;
                this.intervalId = setInterval(() => this.setTime(), 1000);
            }

            stop() {
                this.isRunning = false;
                if (this.intervalId) {
                    clearInterval(this.intervalId);
                    this.intervalId = null;
                }
            }

            setTime() {
                if (mainPlayerInstance && mainPlayerInstance.getCurrentTime) {
                    const currentTime = Math.floor(mainPlayerInstance.getCurrentTime());
                    const currentSegment = document.querySelector(`[data-segment-index="${currentSegmentIndex}"]`);
                    if (currentSegment) {
                        const playerElement = document.getElementById(`VideoPlayer_${currentSegment.dataset.myModal}`);
                        if (playerElement) {
                            const totalTime = parseInt(playerElement.dataset.urltimesec);
                            const remainingTime = Math.max(0, totalTime - currentTime);
                            this.totalSeconds = remainingTime;
                        }
                    }
                }

                if (this.totalSeconds < 0) {
                    this.totalSeconds = 0;
                }

                const hoursLabel = document.getElementById('mainCountdown_Hours');
                const minutesLabel = document.getElementById('mainCountdown_Minutes');
                const secondsLabel = document.getElementById('mainCountdown_Seconds');
                
                if (hoursLabel) hoursLabel.innerHTML = this.pad(parseInt(this.totalSeconds / 3600));
                if (minutesLabel) minutesLabel.innerHTML = this.pad(parseInt((this.totalSeconds / 60) % 60));
                if (secondsLabel) secondsLabel.innerHTML = this.pad(this.totalSeconds % 60);
            }

            pad(val) {
                return val.toString().padStart(2, '0');
            }

            getFormattedTime() {
                const hours = Math.floor(this.totalSeconds / 3600);
                const minutes = Math.floor((this.totalSeconds % 3600) / 60);
                const seconds = this.totalSeconds % 60;
                return `${this.pad(hours)}:${this.pad(minutes)}:${this.pad(seconds)}`;
            }
        }

        // 格式化時間
        function formatTime(seconds) {
            const hours = Math.floor(seconds / 3600);
            const minutes = Math.floor((seconds % 3600) / 60);
            const remainingSeconds = seconds % 60;
            return `${hours.toString().padStart(2, '0')}:${minutes.toString().padStart(2, '0')}:${remainingSeconds.toString().padStart(2, '0')}`;
        }

        // 更新主要播放器的進度條和時間顯示
        function updateMainVideoBar() {
            if (!mainPlayerInstance || !mainPlayerInstance.getCurrentTime) return;
            
            try {
                const currentTime = Math.floor(mainPlayerInstance.getCurrentTime());
                const totalTime = mainPlayerInstance.getDuration ? Math.floor(mainPlayerInstance.getDuration()) : 1;
                const percentage = totalTime > 0 ? Math.floor((currentTime / totalTime) * 100) : 0;
                
                // 更新進度條
                const videoBar = document.getElementById('mainVideoBar');
                if (videoBar) {
                    videoBar.style.width = `${Math.min(100, percentage)}%`;
                    videoBar.setAttribute('aria-valuenow', percentage);
                }
                
                // 更新進度文字
                const progressText = document.getElementById('mainProgressText');
                if (progressText) {
                    progressText.textContent = percentage + '%';
                }
                
                // 更新已觀看時間
                const watchedTimeElement = document.getElementById('mainWatchedTime');
                if (watchedTimeElement) {
                    watchedTimeElement.textContent = formatTime(currentTime);
                }

                // 更新倒數計時器
                if (mainCountdown) {
                    mainCountdown.setTime();
                }
            } catch (error) {
                console.error('更新進度條時發生錯誤:', error);
            }
        }

        // 切換到指定片段
        function switchToSegment(index, segmentId, myModal) {
            // 儲存當前片段的進度
            if (mainPlayerInstance && mainPlayerInstance.getCurrentTime) {
                const currentTime = Math.floor(mainPlayerInstance.getCurrentTime());
                saveCurrentSegmentProgress();
            }

            // 暫停當前播放器
            if (mainPlayerInstance) {
                mainPlayerInstance.pauseVideo();
            }
            if (mainCountdown) {
                mainCountdown.stop();
            }

            // 更新當前片段索引
            currentSegmentIndex = index;

            // 取得目標片段資料
            const playerElement = document.getElementById(`VideoPlayer_${myModal}`);
            if (!playerElement) return;

            const videoId = playerElement.dataset.video;
            const watchtime = parseInt(playerElement.dataset.watchtime) || 0;
            const totalTime = parseInt(playerElement.dataset.urltimesec);
            const title = playerElement.dataset.title;
            const content = playerElement.dataset.content;
            const titleStyle = playerElement.dataset.titleStyle;
            const contentStyle = playerElement.dataset.contentStyle;
            const totalTimeStr = playerElement.dataset.totalTime;

            // 更新標題和描述
            const currentTitle = document.getElementById('currentTitle');
            const currentContent = document.getElementById('currentContent');
            if (currentTitle) {
                currentTitle.textContent = title;
                currentTitle.setAttribute('style', titleStyle);
            }
            if (currentContent) {
                currentContent.textContent = content;
                currentContent.setAttribute('style', contentStyle);
            }

            // 更新總時長
            const mainTotalTime = document.getElementById('mainTotalTime');
            if (mainTotalTime) {
                mainTotalTime.textContent = totalTimeStr;
            }

            // 更新播放清單中的活動狀態
            document.querySelectorAll('.playlist-item').forEach((item, i) => {
                if (i === index) {
                    item.classList.add('active');
                } else {
                    item.classList.remove('active');
                }
            });

            // 更新主要播放器
            if (mainPlayerInstance) {
                mainPlayerInstance.loadVideoById({
                    videoId: videoId,
                    startSeconds: watchtime
                });
            } else {
                // 首次建立播放器
                mainPlayerInstance = new YT.Player('mainVideoPlayer', {
                    width: '100%',
                    height: '100%',
                    videoId: videoId,
                    playerVars: {
                        'playsinline': 1,
                        'start': watchtime,
                        'controls': 1,
                        'disablekb': 0,
                        'rel': 0,
                        'enablejsapi': 1
                    },
                    events: {
                        'onReady': onMainPlayerReady,
                        'onStateChange': onMainPlayerStateChange
                    }
                });
            }

            // 更新倒數計時器
            const remainingTime = Math.max(0, totalTime - watchtime);
            if (!mainCountdown) {
                mainCountdown = new MainCountdown(remainingTime);
            }
            mainCountdown.totalSeconds = remainingTime;
            mainCountdown.setTime();

            // 更新完成狀態
            const currentSegment = document.querySelector(`[data-segment-index="${index}"]`);
            if (currentSegment) {
                const checkbox = document.getElementById('mainIsCompleted');
                const isCompleted = currentSegment.querySelector('.fa-check-circle') !== null;
                if (checkbox) {
                    checkbox.checked = isCompleted;
                }

                // 更新重看按鈕
                const resetBtn = document.getElementById('mainResetBtn');
                if (resetBtn) {
                    resetBtn.setAttribute('onclick', `resetProgress('${segmentId}')`);
                }
            }
        }

        // 儲存當前片段進度
        function saveCurrentSegmentProgress() {
            if (!mainPlayerInstance || !mainPlayerInstance.getCurrentTime) return;

            const currentSegment = document.querySelector(`[data-segment-index="${currentSegmentIndex}"]`);
            if (!currentSegment) return;

            const playerElement = document.getElementById(`VideoPlayer_${currentSegment.dataset.myModal}`);
            if (!playerElement) return;

            const currentTime = Math.floor(mainPlayerInstance.getCurrentTime());
            const videoUrl = playerElement.dataset.url;
            const urlTime = formatTime(currentTime);

            const data = new FormData();
            data.append('time', mainCountdown ? mainCountdown.getFormattedTime() : '00:00:00');
            data.append('EmpID', employeeMainID);
            data.append('UrlTime', urlTime);
            data.append('VideoUrl', videoUrl);
            navigator.sendBeacon('@Url.Action("SaveTime", "Lession")', data);
        }

        // YouTube IFrame API 載入
        var tag = document.createElement('script');
        tag.src = "https://www.youtube.com/iframe_api";
        var firstScriptTag = document.getElementsByTagName('script')[0];
        firstScriptTag.parentNode.insertBefore(tag, firstScriptTag);

        function onYouTubeIframeAPIReady() {
            // 初始化第一個片段
            if (@Model.Segments.Count > 0)
            {
                const firstSegment = document.querySelector('[data-segment-index="0"]');
                if (firstSegment) {
                    switchToSegment(0, firstSegment.dataset.segmentId, firstSegment.dataset.myModal);
                }
            }
        }

        function onMainPlayerReady(event) {
            const currentSegment = document.querySelector(`[data-segment-index="${currentSegmentIndex}"]`);
            if (!currentSegment) return;

            const playerElement = document.getElementById(`VideoPlayer_${currentSegment.dataset.myModal}`);
            if (!playerElement) return;

            const watchtime = parseInt(playerElement.dataset.watchtime) || 0;
            if (watchtime > 0) {
                event.target.seekTo(watchtime, true);
            }

            // 開始定期更新進度
            setInterval(updateMainVideoBar, 1000);
        }

        function onMainPlayerStateChange(event) {
            if (event.data === YT.PlayerState.PLAYING) {
                // 啟動倒數計時
                if (mainCountdown) {
                    mainCountdown.start();
                }
            } else if (event.data === YT.PlayerState.PAUSED || event.data === YT.PlayerState.ENDED) {
                // 停止倒數計時
                if (mainCountdown) {
                    mainCountdown.stop();
                }

                // 儲存進度
                saveCurrentSegmentProgress();
            }

            if (event.data === YT.PlayerState.ENDED) {
                // 標記為完成
                const checkbox = document.getElementById('mainIsCompleted');
                if (checkbox) {
                    checkbox.checked = true;
                    // 更新完成狀態到伺服器
                    const currentSegment = document.querySelector(`[data-segment-index="${currentSegmentIndex}"]`);
                    if (currentSegment) {
                        sendProgressToServer(currentSegment.dataset.segmentId, true);
                    }
                }
            }
        }

        // 發送進度到伺服器
        function sendProgressToServer(trainingInfoMainID, isCompleted) {
            if (!mainPlayerInstance || !mainPlayerInstance.getCurrentTime) return;

            const currentTime = Math.floor(mainPlayerInstance.getCurrentTime());
            
            fetch('@Url.Action("UpdateProgress", "Lession")', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({
                    employeeMainID: employeeMainID,
                    trainingInfoMainID: trainingInfoMainID,
                    watchedTime: currentTime,
                    isCompleted: isCompleted
                })
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    console.log('進度已更新');
                }
            })
            .catch(error => {
                console.error('更新進度時發生錯誤:', error);
            });
        }

        // 重置當前片段進度
        function resetCurrentProgress() {
            const currentSegment = document.querySelector(`[data-segment-index="${currentSegmentIndex}"]`);
            if (!currentSegment) return;

            resetProgress(currentSegment.dataset.segmentId);
        }

        // 重置進度
        function resetProgress(trainingInfoMainID) {
            Swal.fire({
                title: '提示',
                text: "確定要重看該片段嗎？",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#3085d6',
                cancelButtonColor: '#d33',
                confirmButtonText: '確定',
                cancelButtonText: '取消'
            }).then(result => {
                if (result.isConfirmed) {
                    fetch('@Url.Action("UpdateDetl", "Lession")', {
                        method: 'POST',
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                        },
                        body: 'EMTrainingInfoMainID=' + trainingInfoMainID
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.IsSuccess) {
                            Swal.fire({
                                title: '成功',
                                text: data.Msg,
                                icon: 'success',
                                timer: 1500,
                                showConfirmButton: false
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                title: "錯誤",
                                text: data.Msg,
                                icon: "error",
                                showConfirmButton: true
                            });
                        }
                    });
                }
            });
        }

        // 監聽完成狀態變更
        document.getElementById('mainIsCompleted')?.addEventListener('change', function() {
            if (this.checked && mainPlayerInstance && mainPlayerInstance.getCurrentTime) {
                const currentSegment = document.querySelector(`[data-segment-index="${currentSegmentIndex}"]`);
                if (currentSegment) {
                    sendProgressToServer(currentSegment.dataset.segmentId, true);
                }
            }
        });

        // 頁面可見性處理
        document.addEventListener('visibilitychange', () => {
            if (document.hidden) {
                if (mainPlayerInstance && mainPlayerInstance.pauseVideo) {
                    mainPlayerInstance.pauseVideo();
                }

                if (mainCountdown) {
                    mainCountdown.stop();
                }

                saveCurrentSegmentProgress();
            }
        });

        // 定期自動儲存（每30秒）
        window.addEventListener('DOMContentLoaded', () => {
            setInterval(() => {
                saveCurrentSegmentProgress();
            }, 30000);
        });

        // 頁面卸載時儲存進度
        window.addEventListener('beforeunload', function() {
            saveCurrentSegmentProgress();
            if (mainPlayerInstance && mainPlayerInstance.getCurrentTime) {
                const currentSegment = document.querySelector(`[data-segment-index="${currentSegmentIndex}"]`);
                if (currentSegment) {
                    const currentTime = Math.floor(mainPlayerInstance.getCurrentTime());
                    const isCompleted = document.getElementById('mainIsCompleted')?.checked || false;
                    sendProgressToServer(currentSegment.dataset.segmentId, isCompleted);
                }
            }
        });
    </script>
}

