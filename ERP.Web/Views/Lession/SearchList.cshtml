@model ERP.Web.Controllers.Lession.LessionSearchListViewModel
@{
    ViewData["Title"] = "課程管理列表";
}

<div class="container-fluid">
    <div class="row mb-3">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="mb-0"><i class="fas fa-list"></i> 課程管理列表</h2>
            <div>
                <a href="@Url.Action("Create", "Lession")" class="btn btn-primary">
                    <i class="fas fa-plus"></i> 新增課程片段
                </a>
                <a href="@Url.Action("Index", "Lession")" class="btn btn-secondary">
                    <i class="fas fa-arrow-left"></i> 返回課程列表
                </a>
            </div>
        </div>
    </div>
    <hr />

    @if (Model.LessionListWithSegmentCount != null && Model.LessionListWithSegmentCount.Any())
    {
        <div class="row">
            <div class="col-12">
                <div class="table-responsive">
                    <table class="table table-striped table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th style="width: 5%;">序號</th>
                                <th style="width: 30%;">課程名稱</th>
                                <th style="width: 15%;">片段數量</th>
                                <th style="width: 20%;">最後修改時間</th>
                                <th style="width: 30%;" class="text-center">操作</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                            }
                            @foreach (var item in Model.LessionListWithSegmentCount)
                            {
                                <tr>
                                    <td>@index</td>
                                    <td>
                                        <strong>@item.LessionMain.LessionName</strong>
                                    </td>
                                    <td>
                                        <span class="badge bg-info">@item.SegmentCount 個片段</span>
                                    </td>
                                    <td>
                                        <small class="text-muted">
                                            @item.LessionMain.ModifyDate.ToString("yyyy-MM-dd HH:mm:ss")
                                        </small>
                                    </td>
                                    <td class="text-center">
                                        <a href="@Url.Action("Details", "Lession", new { id = item.LessionMain.ID })" 
                                           class="btn btn-sm btn-primary">
                                            <i class="fas fa-eye"></i> 查看詳情
                                        </a>
                                    </td>
                                </tr>
                                index++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
    else
    {
        <div class="alert alert-info">
            <i class="fas fa-info-circle"></i> 目前沒有可用的課程。
        </div>
    }
</div>

