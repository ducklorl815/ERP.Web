@model ERP.Web.Service.ViewModels.SeatMapViewModel_result
@using ERP.Web.Service.Helper

<link href="~/css/seatmap/public.css" rel="stylesheet" />
<link href="~/css/vueslider.css" rel="stylesheet" />
<!-- Font Awesome 6 (Free) -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">

@{
    // ========== 座位圖初始設定 ==========
    
    // 計算座位圖的最大行列數（最小為 10）
    var maxRow = 10;
    var maxCol = 10;
    
    if (Model.SeatMap.Count() > 0)
    {
        maxRow = Model.SeatMap.Max(x => int.Parse(x.Row.ToString()));
        maxCol = Model.SeatMap.Max(x => int.Parse(x.Col.ToString()));
        maxRow = (maxRow < 10) ? 10 : maxRow;
        maxCol = (maxCol < 10) ? 10 : maxCol;
    }

    // 用於追蹤員工名稱出現次數（待實作功能）
    var previousEmpNames = new Dictionary<string, int>();
}

<!-- ========== 自訂樣式：座位與椅子icon ========== -->
<style>
    .seat {
        position: relative;
        width: 48px;
        height: 48px;
        /* 這裡不要用 flex，會影響絕對定位 */
        display: inline-block;
        vertical-align: top;
    }

    .chair-icon {
        width: 100%;
        height: 100%;
        background-color: black;
        mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 36 36'><path d='M20 8V6c0-1.65-1.35-3-3-3H7C5.35 3 4 4.35 4 6v2c-1.65 0-3 1.35-3 3v5c0 1.65 1.35 3 3 3v1c0 .55.45 1 1 1s1-.45 1-1v-1h12v1c0 .55.45 1 1 1s1-.45 1-1v-1c1.65 0 3-1.35 3-3v-5c0-1.65-1.35-3-3-3M6 6c0-.55.45-1 1-1h10c.55 0 1 .45 1 1v2.78c-.61.55-1 1.34-1 2.22v2H7v-2c0-.88-.39-1.67-1-2.22zm15 10c0 .55-.45 1-1 1H4c-.55 0-1-.45-1-1v-5c0-.55.45-1 1-1s1 .45 1 1v4h14v-4c0-.55.45-1 1-1s1 .45 1 1z'/></svg>") no-repeat center;
        -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='-2 0 27 28'><path d='M20 8V6c0-1.65-1.35-3-3-3H7C5.35 3 4 4.35 4 6v2c-1.65 0-3 1.35-3 3v5c0 1.65 1.35 3 3 3v1c0 .55.45 1 1 1s1-.45 1-1v-1h12v1c0 .55.45 1 1 1s1-.45 1-1v-1c1.65 0 3-1.35 3-3v-5c0-1.65-1.35-3-3-3M6 6c0-.55.45-1 1-1h10c.55 0 1 .45 1 1v2.78c-.61.55-1 1.34-1 2.22v2H7v-2c0-.88-.39-1.67-1-2.22zm15 10c0 .55-.45 1-1 1H4c-.55 0-1-.45-1-1v-5c0-.55.45-1 1-1s1 .45 1 1v4h14v-4c0-.55.45-1 1-1s1 .45 1 1z'/></svg>") no-repeat center;
    }

    .SeatSign {
        position: absolute;
        top: 8px; /* 椅背位置 */
        left: 50%;
        transform: translateX(-44%);
        font-size: 10px;
        font-weight: bold;
        color: red;
    }

    .TicketID {
        position: absolute;
        bottom: 0px !important; /* 直接貼齊 seat 的最下方 */
        left: 50%; /* 水平置中 */
        transform: translateX(0%);
        font-size: 8px;
        font-weight: bold;
        color: #333;
        white-space: nowrap;
        z-index: 9999
    }
</style>

<!-- ========== 工具列：模式選擇開關（Vue控制） ========== -->
<div id="app" class="row">
    <div class="w-8 d-flex" style="align-items: center;">
        <label class="col-sm-8 col-form-label font-weight-bold text-sm-right p-1">新增障礙物</label>
        <div id="Stuff" class="col-sm-4 app p-1">
            <label>
                <input id="IsStuff" type="checkbox" v-model="IsStuff" />
                <span class="slider"></span>
            </label>
        </div>
    </div>
    <div class="w-8 d-flex" style="align-items: center;">
        <label class="col-sm-8 col-form-label font-weight-bold text-sm-right p-1">新增座位</label>
        <div id="Stuff" class="col-sm-4 app p-1">
            <label>
                <input id="IsUsing" type="checkbox" v-model="IsUsing" />
                <span class="slider"></span>
            </label>
        </div>
    </div>
    <div class="w-8 d-flex" style="align-items: center;">
        <label class="col-sm-8 col-form-label font-weight-bold text-sm-right p-1">新增走道</label>
        <div id="Stuff" class="col-sm-4 app p-1">
            <label>
                <input id="IsRoad" type="checkbox" v-model="IsRoad" />
                <span class="slider"></span>
            </label>
        </div>
    </div>
</div>

<!-- ========== 座位圖主容器 ========== -->
<div class="ibox">
    <div class="ibox-content cinema-hall" style="background-color:#1a1a1a; padding: 2rem;">
        
        <!-- 螢幕區域 -->
        <div class="screen-container">
            <div class="screen-3d">
                <div class="screen-label">螢幕 SCREEN</div>
            </div>
            <div class="screen-glow"></div>
        </div>

        <!-- 場館資訊 -->
        <div class="venue-header">
            <h4 class="venue-title">XXX 分公司</h4>
            <p class="venue-subtitle">Cinema Seat Map</p>
        </div>

        <!-- 座位圖網格 -->
        <div class="seat-map mt-4">
            @* 
                迴圈說明：
                - 第一行顯示列號（1, 2, 3...）
                - 之後每行顯示：行號 + 座位 + 行號
                - rowLabel：行號標籤（A, B, C...）
            *@
            
            @* ========== 第一行：列號標題 (1, 2, 3...) ========== *@
            <div class="d-flex align-items-center justify-content-center column-header">
                <div class="solid"></div> @* 左側空白 *@
                @for (int colIndex = 1; colIndex <= maxCol; colIndex++)
                {
                    <div class="solid">
                        <span>@colIndex</span>
                    </div>
                }
                <div class="solid"></div> @* 右側空白 *@
            </div>

            @* ========== 座位行 ========== *@
            @for (int rowIndex = 2; rowIndex <= maxRow; rowIndex++)
            {
                var rowLabel = await Helpers.GetLetterSequence(rowIndex);
                
                <div class="d-flex align-items-center justify-content-center seat-row-line">
                    @* 左側行號 *@
                    <div class="solid">
                        <span>@rowLabel</span>
                    </div>

                    @* 座位格 *@
                    @for (int colIndex = 1; colIndex <= maxCol; colIndex++)
                    {
                        // 取得此位置的座位資料（rowIndex 直接對應資料庫的 Row）
                        var seatData = Model.SeatMap.FirstOrDefault(x => x.Row == rowIndex && x.Col == colIndex);
                        var seatLabel = $"{rowLabel}{colIndex}";
                        var isAdmin = seatData?.Border?.Contains("Admin") ?? false;
                        var isUsing = seatData?.Status == "IsUsing";
                        var hasData = seatData != null;
                        
                        <div class="seat @(seatData?.Status)" 
                             style="background-color:@seatData?.Colorcode;color:#676a6c;align-content:center"
                             data-status="@(seatData?.Status ?? "")"
                             data-border="@(seatData?.Border ?? "")"
                             data-sign="@seatLabel"
                             data-ticketid="@(seatData?.TicketID ?? "")"
                             data-rowcol="row_@rowIndex&col_@colIndex">
                            
                            <div style="text-align: center;">
                                @if (hasData)
                                {
                                    @if (isAdmin)
                                    {
                                        // 先執行 C# 程式碼（記錄員工名稱出現次數）
                                        previousEmpNames[seatData.TicketID] = previousEmpNames.ContainsKey(seatData.TicketID)
                                            ? previousEmpNames[seatData.TicketID] + 1
                                            : 1;
                                        
                                        // 管理員座位顯示
                                        <span>@seatLabel @seatData?.Border</span>
                                    }
                                    else if (isUsing)
                                    {
                                        @* 使用中座位：顯示椅子 icon *@
                                        <div class="seat @seatData?.Status">
                                            <div class="chair-icon"></div>
                                            <span class="SeatSign">@seatLabel</span>
                                        </div>
                                        <span class="TicketID" style="position: absolute; bottom: 2px; left: 4px; font-size: 6px; font-weight: bold;">
                                            A2508170001
                                        </span>
                                    }
                                    else
                                    {
                                        @* 其他狀態座位 *@
                                        <span class="TicketID" style="font-size:8px">@seatData.TicketID</span>
                                        <span>@seatLabel</span>
                                    }
                                }
                                else
                                {
                                    @* 空座位 *@
                                    <span>@seatLabel</span>
                                }
                            </div>
                        </div>
                    }
                    
                    @* 右側行號 *@
                    <div class="solid">
                        <span>@rowLabel</span>
                    </div>
                </div>
            }
        </div>

        <!-- 圖例說明 -->
        <div class="legend-container">
            <div class="legend-title">座位狀態說明</div>
            <div class="legend-items">
                <div class="legend-item">
                    <div class="legend-icon seat-available"></div>
                    <span>可選座位</span>
                </div>
                <div class="legend-item">
                    <div class="legend-icon seat-occupied"></div>
                    <span>已佔用</span>
                </div>
                <div class="legend-item">
                    <div class="legend-icon seat-blocked"></div>
                    <span>障礙物</span>
                </div>
                <div class="legend-item">
                    <div class="legend-icon seat-aisle"></div>
                    <span>走道</span>
                </div>
            </div>
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/vue/dist/vue.js"></script>
<script src="~/js/seatmap/public.js"></script>
<script src="~/js/seatmap/datamaintain.js"></script>

