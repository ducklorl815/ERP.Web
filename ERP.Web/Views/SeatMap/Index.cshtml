@model ERP.Web.Service.ViewModels.SeatMapViewModel_result
@using ERP.Web.Service.Helper

<link href="~/css/seatmap/public.css" rel="stylesheet" />
<link href="~/css/vueslider.css" rel="stylesheet" />
<!-- Font Awesome 6 (Free) -->
<link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css" rel="stylesheet">
@{
    var maxRow = 10;
    var maxCol = 10;
    if (Model.SeatMap.Count() > 0)
    {
        maxRow = Model.SeatMap.Max(x => int.Parse(x.Row.ToString()));
        maxCol = Model.SeatMap.Max(x => int.Parse(x.Col.ToString()));
        maxRow = (maxRow == null || maxRow < 10) ? 10 : maxRow;
        maxCol = (maxCol == null || maxCol < 10) ? 10 : maxCol;
    }

    //var staticSeatMap = new List<dynamic> {
    //    new { Row = 1, Col = 1, Colorcode = "#FFD700", Status = "using", BoxNumber = "台北", Location = "台北", TicketID = "T01A5AA00" ,Border ="TopBorder LeftBorder"},
    //    new { Row = 2, Col = 2, Colorcode = "#90EE90", Status = "using", BoxNumber = "台北", Location = "台北", TicketID = "T02B50A24",Border ="DownBorder LeftBorder"},
    //};

    var previousEmpNames = new Dictionary<string, int>();
}
<style>
    .seat {
        position: relative;
        width: 48px;
        height: 48px;
        /* 這裡不要用 flex，會影響絕對定位 */
        display: inline-block;
        vertical-align: top;
    }

    .chair-icon {
        width: 100%;
        height: 100%;
        background-color: black;
        mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 36 36'><path d='M20 8V6c0-1.65-1.35-3-3-3H7C5.35 3 4 4.35 4 6v2c-1.65 0-3 1.35-3 3v5c0 1.65 1.35 3 3 3v1c0 .55.45 1 1 1s1-.45 1-1v-1h12v1c0 .55.45 1 1 1s1-.45 1-1v-1c1.65 0 3-1.35 3-3v-5c0-1.65-1.35-3-3-3M6 6c0-.55.45-1 1-1h10c.55 0 1 .45 1 1v2.78c-.61.55-1 1.34-1 2.22v2H7v-2c0-.88-.39-1.67-1-2.22zm15 10c0 .55-.45 1-1 1H4c-.55 0-1-.45-1-1v-5c0-.55.45-1 1-1s1 .45 1 1v4h14v-4c0-.55.45-1 1-1s1 .45 1 1z'/></svg>") no-repeat center;
        -webkit-mask: url("data:image/svg+xml;utf8,<svg xmlns='http://www.w3.org/2000/svg' viewBox='-2 0 27 28'><path d='M20 8V6c0-1.65-1.35-3-3-3H7C5.35 3 4 4.35 4 6v2c-1.65 0-3 1.35-3 3v5c0 1.65 1.35 3 3 3v1c0 .55.45 1 1 1s1-.45 1-1v-1h12v1c0 .55.45 1 1 1s1-.45 1-1v-1c1.65 0 3-1.35 3-3v-5c0-1.65-1.35-3-3-3M6 6c0-.55.45-1 1-1h10c.55 0 1 .45 1 1v2.78c-.61.55-1 1.34-1 2.22v2H7v-2c0-.88-.39-1.67-1-2.22zm15 10c0 .55-.45 1-1 1H4c-.55 0-1-.45-1-1v-5c0-.55.45-1 1-1s1 .45 1 1v4h14v-4c0-.55.45-1 1-1s1 .45 1 1z'/></svg>") no-repeat center;
    }

    .SeatSign {
        position: absolute;
        top: 8px; /* 椅背位置 */
        left: 50%;
        transform: translateX(-44%);
        font-size: 10px;
        font-weight: bold;
        color: red;
    }

    .TicketID {
        position: absolute;
        bottom: 0px !important; /* 直接貼齊 seat 的最下方 */
        left: 50%; /* 水平置中 */
        transform: translateX(0%);
        font-size: 8px;
        font-weight: bold;
        color: #333;
        white-space: nowrap;
        z-index: 9999
    }
</style>
<div id="app" class="row">
    <div class="w-8 d-flex" style="align-items: center;">
        <label class="col-sm-8 col-form-label font-weight-bold text-sm-right p-1">新增障礙物</label>
        <div id="Stuff" class="col-sm-4 app p-1">
            <label>
                <input id="IsStuff" type="checkbox" v-model="IsStuff" value="false" />
                <span class="slider"></span>
            </label>
        </div>
    </div>
    <div class="w-8 d-flex" style="align-items: center;">
        <label class="col-sm-8 col-form-label font-weight-bold text-sm-right p-1">新增座位</label>
        <div id="Stuff" class="col-sm-4 app p-1">
            <label>
                <input id="IsUsing" type="checkbox" v-model="IsUsing" value="false" />
                <span class="slider"></span>
            </label>
        </div>
    </div>
    <div class="w-8 d-flex" style="align-items: center;">
        <label class="col-sm-8 col-form-label font-weight-bold text-sm-right p-1">新增走道</label>
        <div id="Stuff" class="col-sm-4 app p-1">
            <label>
                <input id="IsRoad" type="checkbox" v-model="IsRoad" value="false" />
                <span class="slider"></span>
            </label>
        </div>
    </div>
</div>
<div class="ibox">
    <div class="ibox-content" style="background-color:black">
        <div class="row justify-content-start">
            <div class="d-flex align-items-center">
                <div class="col-sm-6 px-0 py-1">
                    <div>XXX</div>
                </div>
                <label class="col-sm-6 col-form-label font-weight-bold text-sm-left p-1">分公司</label>
            </div>
        </div>

        <div class="seat-map mt-4">
            @for (int i = 1; i <= maxRow + 1; i++)
            {
                var letterSequence = await Helpers.GetLetterSequence(i);
                <div class="d-flex align-items-center justify-content-center">
                    @if (i == 1)
                    {
                        @for (int j = 1; j <= maxCol; j++)
                        {
                            <div class="solid" style="position: relative">
                                <i class="fa-solid fa-sort-down fa-xl fa-unselected" data-status="unused" data-col="col_@(j)" style="position: absolute;visibility:hidden"></i>
                                <span style="display: block;">@(j)</span>
                            </div>
                        }
                    }
                    else
                    {
                        <div class="solid">
                            <span>@letterSequence</span>
                            <i class="fa-solid fa-caret-right fa-xl fa-unselected" style="visibility:hidden" data-status="unused" data-row="row_@(i - 1)"></i>
                        </div>

                        @for (int j = 1; j <= maxCol; j++)
                        {
                            var item = Model.SeatMap.FirstOrDefault(x => x.Row == i && x.Col == j);
                            <div class="seat" style="background-color:@item?.Colorcode ;color:#676a6c;align-content:center"
                                 data-status="@item?.Status"
                                 data-Border="@item?.Border"
                                 data-sign="@letterSequence@j"
                                 data-TicketID="@item?.TicketID"
                                 data-rowcol="row_@(i - 1)&col_@(j)">
                                @if (item != null)
                                {
                                    <div style="text-align: center;">
                                        @if (item.Border.Contains("Admin"))
                                        {
                                            <span>@letterSequence@j @item?.Border</span>
                                            previousEmpNames[item?.TicketID] = previousEmpNames.ContainsKey(item?.TicketID)
                                            ? previousEmpNames[item?.TicketID] + 1
                                            : 1;
                                        }
                                        else
                                        {
                                            if (item.Status == "IsUsing")
                                            {
                                                <div class="seat @item?.Status">
                                                    <div class="chair-icon"></div>
                                                    <span class="SeatSign">@letterSequence@j</span>
                                                </div>
                                               <span class="TicketID" style="position: absolute; bottom: 2px; left: 4px; font-size: 6px; font-weight: bold;">
                                                    A2508170001
                                                </span>
                                            }
                                            else
                                            {

                                                <span class="TicketID" style="font-size:8px">@item.TicketID</span>
                                                <span>@letterSequence@j</span>
                                            }

                                        }
                                    </div>
                                }
                                else
                                {
                                    <div style="text-align: center;align-self:center">
                                        <span>@letterSequence@j</span>
                                    </div>
                                }
                            </div>
                        }
                        <div class="solid">
                            <span>@letterSequence</span>
                            <i class="fa-solid fa-caret-right fa-xl fa-unselected" style="visibility:hidden" data-status="unused" data-row="row_@(i - 1)"></i>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
</div>
<script src="https://cdn.jsdelivr.net/npm/vue/dist/vue.js"></script>
<script src="~/js/seatmap/public.js"></script>
<script src="~/js/seatmap/datamaintain.js"></script>
<script>

</script>
